<diagram xmlns="https://prefigure.org"
         dimensions="(360,160)" margins="5">
  <coordinates bbox="(-1,-1,10,4)">
    <rectangle at="box" center="(7.5,1.5)" dimensions="(5,4.5)"
               fill="lightgray" stroke="black"/>
    <network directed="yes" labels="yes" node-fill="#ccccff"
             node-size="15">
      <node at="1" p="(0,3)" font-size="20">1</node>
      <node at="2" p="(0,0)" font-size="20">2</node>
      <node at="3" p="(3,3)" font-size="20">3</node>
      <node at="4" p="(3,0)" font-size="20">4</node>
      <node at="5" p="(6,3)" font-size="20">5</node>
      <node at="6" p="(6,0)" font-size="20">6</node>
      <node at="7" p="(9,3)" font-size="20">7</node>
      <node at="8" p="(9,0)" font-size="20">8</node>
      <edge vertices="(1,2)"/>
      <edge vertices="(1,3)"/>
      <edge vertices="(2,4)"/>
      <edge vertices="(3,2)"/>
      <edge vertices="(3,5)"/>
      <edge vertices="(4,2)"/>
      <edge vertices="(4,6)"/>
      <edge vertices="(5,6)"/>
      <edge vertices="(5,7)"/>
      <edge vertices="(5,8)"/>
      <edge vertices="(6,8)"/>
      <edge vertices="(7,5)"/>
      <edge vertices="(7,8)"/>
      <edge vertices="(8,6)"/>
      <edge vertices="(8,7)"/>
    </network>
  </coordinates>

  <annotations text="The same internet as before with a box drawn around pages five, six,, seven, and eight">
    <annotation ref="box"
                text="Four pages are contained in this box.  There are links going into the box but none coming out"/>
    <annotation ref="node-1"
                text="The first page links to pages two and three">
      <annotation ref="edge-1-2"/>
      <annotation ref="edge-1-3"/>
    </annotation>
    <annotation ref="node-2"
                text="The second page links to page four">
      <annotation ref="edge-2-4"/>
    </annotation>
    <annotation ref="node-3"
                text="The third page links to pages two and five">
      <annotation ref="edge-3-2"/>
      <annotation ref="edge-3-5"/>
    </annotation>
    <annotation ref="node-4"
                text="The fourth page links to pages two and six">
      <annotation ref="edge-4-2"/>
      <annotation ref="edge-4-6"/>
    </annotation>
    <annotation ref="node-5"
                text="The fifth page links to pages six, seven and eight">
      <annotation ref="edge-5-6"/>
      <annotation ref="edge-5-7"/>
      <annotation ref="edge-5-8"/>
    </annotation>
    <annotation ref="node-6"
                text="The sixth page links to page eight">
      <annotation ref="edge-6-8"/>
    </annotation>
    <annotation ref="node-7"
                text="The seventh page links to pages one, five and eight">
      <annotation ref="edge-7-5"/>
      <annotation ref="edge-7-8"/>
    </annotation>
    <annotation ref="node-8"
                text="The eighth page links to pages six and seven">
      <annotation ref="edge-8-6"/>
      <annotation ref="edge-8-7"/>
    </annotation>
  </annotations>
</diagram>
