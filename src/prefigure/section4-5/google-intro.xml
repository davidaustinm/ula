<diagram xmlns="https://prefigure.org"
         dimensions="(180, 180)" margins="5">
  <coordinates bbox="(-1,-1,4,4)">
    <network directed="yes" labels="yes" node-fill="#ccccff"
             node-size="20" edge-spread="20">
      <node at="1" p="(0,3)" font-size="20">1</node>
      <node at="2" p="(0,0)" font-size="20">2</node>
      <node at="3" p="(3,1.5)" font-size="20">3</node>
      <edge vertices="(1,2)"/>
      <edge vertices="(2,1)"/>
      <edge vertices="(1,3)"/>
      <edge vertices="(3,1)"/>
      <edge vertices="(3,2)"/>
    </network>
  </coordinates>

  <annotations text="An internet with three pages">
    <annotation ref="node-1"
                text="The first page labeled one links to pages two and three">
      <annotation ref="edge-1-2"/>
      <annotation ref="edge-1-3"/>
    </annotation>
    <annotation ref="node-2"
                text="The second page labeled two links to page one">
      <annotation ref="edge-2-1"/>
    </annotation>
    <annotation ref="node-3"
                text="The third page labeled three links to pages one and two">
      <annotation ref="edge-3-1"/>
      <annotation ref="edge-3-2"/>
    </annotation>
  </annotations>
</diagram>
