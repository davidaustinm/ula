<diagram xmlns="https://prefigure.org"
         dimensions="(200, 200)" margins="5">
  <definition>p=(3,4)</definition>
  <coordinates bbox="(-1,-1,5,5)">
    <axes at="axes" decorations="no"/>
    <angle-marker at="angle" points="((3,0),(0,0),p)">
      <m>\theta</m>
    </angle-marker>
    <triangle at="triangle" vertices="((3,0),(0,0),p)" stroke="blue"/>
    <point at="p" p="(3,4)" fill="blue">
      <m>(a,b)</m>
    </point>
    <line at="horiz" endpoints="((0,0),(3,0))" endpoint-offsets="(3,-3)"
          stroke="blue"/>
    <line at="hyp" endpoints="((0,0),p)" endpoint-offsets="(3,-5)"
          stroke="blue"/>
    <line at="vert" endpoints="(p,(3,0))" endpoint-offsets="(5,-3)"
          stroke="blue"/>
    <label at="horiz-label" anchor="(1.5,0)"
           alignment="s" offset="(0,-5)"><m>a</m></label>
    <label at="vert-label" anchor="(3,2)"
           alignment="e" offset="(6,0)"><m>b</m></label>
    <label at="hyp-label" anchor="(1.5,2)"
           alignment="nw" offset="(-2,2)"><m>r</m></label>
  </coordinates>

  <annotations text="Representing a point in polar coordinates">
    <annotation ref="axes" text="The standard set of axes"/>
    <annotation ref="p" text="The point a b"/>
    <annotation ref="group"
                text="The point defines a right triangle">
      <annotation ref="horiz"
                  text="The horizontal side has length a">
        <annotation ref="horiz-label"/>
      </annotation>
      <annotation ref="vert"
                  text="The vertical side has length b">
        <annotation ref="vert-label"/>
      </annotation>
      <annotation ref="hyp"
                  text="The hypotenus has length r">
        <annotation ref="hyp-label"/>
      </annotation>
      <annotation ref="angle"
                  text="The angle with the horizontal axis is theta"/>
    </annotation>
  </annotations>
</diagram>
