<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes/>
    <line at="line-1" endpoints="((0,0),(1,1))" stroke="gray"
          infinite="yes"/>
    <line at="line-2" endpoints="((0,0),(-1,1))" stroke="gray"
          infinite="yes"/>
  </coordinates>
  <annotations text="Two perpendicular lines defined by the vectors v one and v two">
    <annotation ref="line-1"
                text="The line defined by v one"/>
    <annotation ref="line-2"
                text="The line defined by v two"/>
  </annotations>
</diagram>
