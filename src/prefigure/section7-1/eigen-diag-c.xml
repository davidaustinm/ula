<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(3,0)</definition>
  <definition>v2=(0,-1)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <repeat at="grid" parameter="i=-4..4">
      <line endpoints="(i*v1,i*v1+v2)" stroke="lightgray" infinite="yes"/>
      <line endpoints="(i*v2,i*v2+v1)" stroke="lightgray" infinite="yes"/>
    </repeat>
    <polygon at="square" points="((0,0),v1,v1+v2,v2)" closed="yes"
                 fill="#f77" stroke="gray"/>
    <axes at="axes"/>
  </coordinates>

  <annotations text="Multiplying by D stretches horizontally by a factor of 3 and flips in the horizontal axis">
    <annotation ref="axes" text="The standard set of axes"/>
    <annotation ref="grid" text="The transformed coordinate grid"/>
    <annotation ref="square"
                text="The unit square has been transformed into a rectangle of width three and height one"/>
  </annotations>
</diagram>
