<diagram xmlns="https://prefigure.org"
         dimensions="(280, 280)" margins="5">
  <definition>v=(2,1)</definition>
  <definition>w=(-1,3)</definition>
  <coordinates bbox="(-6,-6,6,6)">
    <grid-axes spacings="((-6,1,6),(-6,1,6))" decorations="no"
               xlabel="x" ylabel="y"/>
    <line at="v-line" endpoints="((0,0),v)" infinite="yes"
          stroke="black" thickness="1"/>
    <line at="v-line-trans" endpoints="(w,v+w)" infinite="yes"
          stroke="black" thickness="1"/>
    <vector at="v" v="v" stroke="blue">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="w" stroke="blue" alignment="n" offset="(0,5)">
      <m>\wvec</m>
    </vector>

    <vector at="v-trans-2" v="-2*v" tail="w" stroke="#aaa"
              alignment="n" offset="(0,5)">
      <m>-2\vvec</m>
    </vector>
    <vector at="sum-2" v="-2*v + w" stroke="gray"/>
            
    <vector at="v-trans-1" v="-1*v" tail="w" stroke="#aaa"
              alignment="n" offset="(0,5)">
      <m>-\vvec</m>
    </vector>
    <vector at="sum-1" v="-1*v + w" stroke="gray"/>

    <vector at="v-trans1" v="v" tail="w" stroke="#aaa"
              alignment="nw">
      <m>\vvec</m>
    </vector>
    <vector at="sum1" v="v + w" stroke="gray"/>

    <vector at="v-trans2" v="2*v" tail="w" stroke="#aaa"
              alignment="nw">
      <m>2\vvec</m>
    </vector>
    <vector at="sum2" v="2*v + w" stroke="gray"/>
  </coordinates>

  <annotations text="Two vectors v and w and the parallel lines formed by scalar multiples of v and scalar multiples of v added to w">
    <annotation ref="v-data"
                text="The vector v and the line defined by its scalar multiples">
      <annotation ref="v"
                  text="The vector v"/>
      <annotation ref="v-line"
                  text="The line formed by scalaar multiples of v"/>
    </annotation>
    <annotation ref="v-trans-data"
                text="The scalar multiples of v added to w form a line parallel to the line of scalar multiples of v">
      <annotation ref="w"
                  text="The vector w"/>
      <annotation ref="v-2"
                  text="The vector negative 2 times v added to w">
        <annotation ref="v-trans-2"/>
        <annotation ref="sum-2"/>
        <annotation ref="w"/>
      </annotation>
      <annotation ref="v-1"
                  text="The vector negative 1 times v added to w">
        <annotation ref="v-trans-1"/>
        <annotation ref="sum-1"/>
        <annotation ref="w"/>
      </annotation>
      <annotation ref="v1"
                  text="The vector v added to w">
        <annotation ref="v-trans1"/>
        <annotation ref="sum1"/>
        <annotation ref="w"/>
      </annotation>
      <annotation ref="v2"
                  text="The vector 2 times v added to w">
        <annotation ref="v-trans2"/>
        <annotation ref="sum2"/>
        <annotation ref="w"/>
      </annotation>
      <annotation ref="v-line-trans"
                  text="The line formed by scalar multiples of v added to w"/>
    </annotation>
  </annotations>
</diagram>
