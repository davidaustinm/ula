<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <coordinates bbox="(-1,-1,6,6)">
    <grid-axes spacings="((-1,1,6),(-1,1,6))"
               decorations="no" xlabel="x" ylabel="y"/>
    <vector at="v" v="(3,1)" stroke="gray" alignment="se"
            label-location="0.5">
      <m>\vvec</m>
    </vector>
    <vector at="v-trans" v="(3,1)" tail="(2,3)" stroke="gray" alignment="nw"
            label-location="0.5">
      <m>\vvec</m>
    </vector>
    <vector at="w-trans" v="(2,3)" tail="(3,1)" stroke="gray" alignment="se"
            label-location="0.5">
      <m>\wvec</m>
    </vector>
    <vector at="w" v="(2,3)" stroke="gray" alignment="nw"
            label-location="0.5">
      <m>\wvec</m>
    </vector>
    <vector at="sum" v="(5,4)" fill="blue" stroke="blue" alignment="nw"
            label-location="0.9">
      <m>\vvec + \wvec</m>
    </vector>
  </coordinates>
  <annotations text="A parallelogram formed by two vectors and their sum drawn as a diagonal of the parallelogram.">
    <annotation ref="sides-v"
                text="Two sides of the parallelogram are formed by the vector v">
      <annotation ref="v"
                  text="The vector v placed at the origin"/>
      <annotation ref="v-trans"
                  text="The vector v placed at the tip of w"/>
    </annotation>
    <annotation ref="sides-w"
                text="Two sides of the parallelogram are formed by the vector w">
      <annotation ref="w"
                  text="The vector w placed at the origin"/>
      <annotation ref="w-trans"
                  text="The vector w placed at the tip of v"/>
    </annotation>
    <annotation ref="sum"
                text="The vector sum v plus w is a diagonal of the parallelogram"/>
  </annotations>
      
</diagram>
