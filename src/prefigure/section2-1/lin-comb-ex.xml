<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)">
  <definition>v=(-1,1)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no" xlabel="x" ylabel="y"/>
    <line at="line" endpoints="((0,0),v)" stroke="gray" infinite="yes"/>
    <vector at="v" v="v" stroke="blue" alignment="ne">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="-2*v" stroke="blue" alignment="ne">
      <m>\wvec</m>
    </vector>
  </coordinates>
  <annotations text="Two vectors v and w that lie on the same line">
    <annotation ref="v"
                text="The vector v"/>
    <annotation ref="w"
                text="The vector w"/>
    <annotation ref="line"
                text="Both vectors v and w lie on the same line"/>
  </annotations>
</diagram>
