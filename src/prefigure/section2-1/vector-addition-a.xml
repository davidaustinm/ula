<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <coordinates bbox="(-1,-1,6,6)">
    <grid-axes spacings="((-1,1,6),(-1,1,6))"
               decorations="no" xlabel="x" ylabel="y"/>
    <vector at="v" v="(3,1)" stroke="gray" alignment="se"
            label-location="0.5">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="(2,3)" tail="(3,1)" stroke="gray" alignment="se"
            label-location="0.5">
      <m>\wvec</m>
    </vector>
    <vector at="sum" v="(5,4)" fill="blue" stroke="blue" alignment="nw"
            label-location="0.9">
      <m>\vvec + \wvec</m>
    </vector>
  </coordinates>
  <annotations text="Two vectors v and w and their vector sum">
    <annotation ref="v"
                text="The vector v drawn from the origin"/>
    <annotation ref="w"
                text="The vector w drawn from the tip of v"/>
    <annotation ref="sum"
                text="The vector sum v plus w"/>
  </annotations>
      
</diagram>
