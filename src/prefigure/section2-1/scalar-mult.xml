<diagram xmlns="https://prefigure.org"
         dimensions="(350,350)" margins="5">
  <coordinates bbox="(-6,-6,6,6)">
    <grid-axes spacings="((-6,1,6),(-6,1,6))" clear-background="yes">
      <xlabel alignment="nw"><m>x</m></xlabel>
      <ylabel alignment="se"><m>y</m></ylabel>
    </grid-axes>
    <line at="line" endpoints="((-6,-3),(6,3))" stroke="gray"/>
    <vector at="v-2" v="(-4,-2)" stroke="black" alignment="se">
      <m>-2\vvec</m>
    </vector>
    <vector at="v2" v="(4,2)" stroke="black" alignment="se">
      <m>2\vvec</m>
    </vector>
    <vector at="v-1" v="(-2,-1)" stroke="black" alignment="se">
      <m>-\vvec</m>
    </vector>
    <vector at="v" v="(2,1)" stroke="blue" alignment="se">
      <m>\vvec</m>
    </vector>
  </coordinates>
  <annotations text="A vector v and several scalar multiples all of which lie on the same line">
    <annotation ref="v"
                text="The vector v having components two, one"/>
    <annotation ref="line"
                text="All the scalar multiples of v lie on this line"/>
    <annotation ref="v2"
                text="The vector 2 times v whose components are four, two"/>
    <annotation ref="v-1"
                text="The vector minus 1 times v whose components are negative two, negative one"/>
    <annotation ref="v-2"
                text="The vector minus 2 times v whose components are negative four, negative two"/>
  </annotations>
</diagram>
