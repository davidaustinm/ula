<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>lambda1=1/0.6</definition>
  <definition>lambda2=1/0.8</definition>
  <definition>g(t,x)=(lambda1**t * x[0], lambda2**t * x[1])</definition>
  <definition>x=[[5,0], [5,1], [5,3], [5,5], [3,5], [1,5], [0,5]]</definition>
  <coordinates bbox="(-6,-6,6,6)">
    <grid at="grid" spacings="((-6,1,6),(-6,1,6))"/>
    <axes at="axes" decorations="no"/>
    <repeat at="curves" parameter="p in x"
            annotate="yes" text="A set of trajectories">
      <repeat at="permute" parameter="k=0..3"
              annotate="yes">
        <definition>f(t)=g(t,p)</definition>
        <parametric-curve function="f" stroke="blue" domain="(-10,10)"
                          arrows="1" arrow-location="-1.3"
                          cliptobbox="yes"/>
        <repeat at="iterates" parameter="k=-3..0"
                annotate="yes">
          <point p="f(k)" size="2.5" fill="black" stroke="none"/>
        </repeat>
        <definition>p=(-p[1],p[0])</definition>
      </repeat>
    </repeat>
  </coordinates>

  <annotations text="Trajectories for a repellor shown in the coordinate system defined by the eigenvectors">
    <annotation ref="grid"
                text="The standard grid and axes">
      <annotation ref="axes"/>
    </annotation>
    <annotation ref="curves"/>
  </annotations>
</diagram>
