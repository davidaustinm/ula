<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(1,1)</definition>
  <definition>v2=(-1,1)</definition>
  <coordinates bbox="(-6,-6,6,6)">
    <repeat at="grid" parameter="i=-6..6">
      <line endpoints="(i*v1,i*v1+v2)" stroke="lightgray" infinite="yes"/>
      <line endpoints="(i*v2,i*v2+v1)" stroke="lightgray" infinite="yes"/>
    </repeat>
    <group at="axes">
      <line endpoints="((0,0),v1)" stroke="black" infinite="yes"/>
      <line endpoints="((0,0),v2)" stroke="black" infinite="yes"/>
    </group>
    <axes at="std-axes" decorations="no" thickness="1" stroke="gray"/>
  </coordinates>
  <annotations text="A grid and axes in the coordinate system defined by the eigenvectors.">
    <annotation ref="std-axes" text="The standard axes"/>
    <annotation ref="grid" text="The grid and axes">
      <annotation ref="axes"/>
    </annotation>
  </annotations>
</diagram>
