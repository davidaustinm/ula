<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-3,-3,3,3)">
    <definition>Re1=(-1,0)</definition>
    <definition>Re2=(0,-1)</definition>
    <definition>Rv=-2*Re1-Re2</definition>
    <grid-axes/>
    <vector at="Re1" v="Re1" stroke="blue" offset="(4,3)" alignment="nw">
      <m>R(\evec_1)</m>
    </vector>
    <vector at="Re2" v="Re2" stroke="blue" alignment="se">
      <m>R(\evec_2)</m>
    </vector>
    <vector at="Rv" v="Rv" stroke="blue" alignment="ne">
      <m>R(\vvec)</m>
    </vector>
  </coordinates>

  <annotations text="After applying the matrix transformation R, we see three vectors:  R of e one, R of e two, and R of v">
    <annotation ref="Re1"
                text="The vector R of e one has components negative one zero"/>
    <annotation ref="Re2"
                text="The vector R of e two has components zero negative one"/>
    <annotation ref="Rv"
                text="The vector R of v has components two one"/>
  </annotations>
</diagram>
    
