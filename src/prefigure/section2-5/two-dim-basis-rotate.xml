<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-3,-3,3,3)">
    <definition>Te1=(0,1)</definition>
    <definition>Te2=(-1,0)</definition>
    <definition>Tv=-2*Te1-Te2</definition>
    <grid-axes/>
    <vector at="Te1" v="Te1" stroke="blue" alignment="ne">
      <m>T(\evec_1)</m>
    </vector>
    <vector at="Te2" v="Te2" stroke="blue" offset="(4,3)" alignment="nw">
      <m>T(\evec_2)</m>
    </vector>
    <vector at="Tv" v="Tv" stroke="blue" alignment="ne">
      <m>T(\vvec)</m>
    </vector>
  </coordinates>

  <annotations text="After applying the matrix transformation T, we see three vectors:  T of e one, T of e two, and T of v">
    <annotation ref="Te1"
                text="The vector T of e one has components zero one"/>
    <annotation ref="Te2"
                text="The vector T of e two has components negative one zero"/>
    <annotation ref="Tv"
                text="The vector T of v has components one negative two"/>
  </annotations>
</diagram>
    
