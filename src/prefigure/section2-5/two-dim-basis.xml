<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-3,-3,3,3)">
    <definition>e1=(1,0)</definition>
    <definition>e2=(0,1)</definition>
    <definition>v=-2*e1-e2</definition>
    <grid-axes/>
    <vector at="e1" v="e1" stroke="blue" alignment="ne">
      <m>\evec_1</m>
    </vector>
    <vector at="e2" v="e2" stroke="blue" alignment="ne">
      <m>\evec_2</m>
    </vector>
    <vector at="v" v="v" stroke="blue" alignment="se">
      <m>\vvec</m>
    </vector>
  </coordinates>

  <annotations text="This two dimensional diagram contains three vectors:  e one, e two, and v">
    <annotation ref="e1"
                text="The vector e one has components one zero"/>
    <annotation ref="e2"
                text="The vector e two has components zero one"/>
    <annotation ref="v"
                text="The vector v has components negative two negative one"/>
  </annotations>
</diagram>
    
