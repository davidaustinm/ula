<diagram xmlns="https://prefigure.org"
         dimensions="(200,170)" margins="(30,30,5,10)">
  <coordinates bbox="(0,0,4.5,15)">
    <axes at="axes" hlabels="(0,1,4)" vlabels="(0,5,15)">
      <xlabel alignment="nw">Quarter</xlabel>
      <ylabel alignment="se">Revenue</ylabel>
    </axes>
    <line at="approx-1" endpoints="((0,11.7),(2.5,11.7))" infinite="no"
          stroke="gray"/>
    <line at="approx-2" endpoints="((2.5,7.85),(4.5,7.85))" infinite="no"
          stroke="gray"/>
    <line at="approx-3" endpoints="((0,10.3),(1.5,10.3))"
          infinite="no" stroke="blue"/>
    <line at="approx-4" endpoints="((1.5,13.1),(2.5,13.1))"
          infinite="no" stroke="blue"/>
    <line at="approx-5" endpoints="((2.5,7.5),(3.5,7.5))"
          infinite="no" stroke="blue"/>
    <line at="approx-6" endpoints="((3.5,8.2),(4.5,8.2))"
          infinite="no" stroke="blue"/>
    <point at="p1" p="(1,10.3)"/>
    <point at="p2" p="(2,13.1)"/>
    <point at="p3" p="(3,7.5)"/>
    <point at="p4" p="(4,8.2)"/>
  </coordinates>

  <annotations text="A representation of a company's revenue by quarter">
    <annotation ref="axes"
                text="The horizontal coordinate represents the quarter and the vertical coordinate represents the revenue"/>
    <annotation ref="approx-1-group"
                text="Using the second basis vector, we obtain averages over the two halves of the year">
      <annotation ref="approx-1"
                  text="During the first half of the year, the average revenue was 11.7 million dollars"/>
      <annotation ref="approx-2"
                  text="During the second half of the year, the average revenue was 7.85 million dollars"/>
    </annotation>
    <annotation ref="approx-group"
                text="With all four basis vectors, we obtain the exact revenue in each quarter">
      <annotation ref="approx-3"/>
      <annotation ref="approx-4"/>
      <annotation ref="approx-5"/>
      <annotation ref="approx-6"/>
      <annotation ref="p1"/>
      <annotation ref="p2"/>
      <annotation ref="p3"/>
      <annotation ref="p4"/>
    </annotation>
  </annotations>
               
</diagram>
