<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(2,1)</definition>
  <definition>v2=(1,2)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <grid at="skew-grid" basis="(v1,v2)" cliptobbox="yes" stroke="gray"/>
    <vector at="v1" v="v1" stroke="black">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="black">
      <m>\vvec_2</m>
    </vector>
  </coordinates>
  <annotations text="Two vectors and the linear combinations they create">
    <annotation ref="v1"
                text="The vector v one"/>
    <annotation ref="v2"
                text="The vector v two"/>
    <annotation ref="skew-grid"
                text="The linear combinations they create are represented by a skewed grid of lines parallel to v one and v two"/>
  </annotations>

</diagram>
