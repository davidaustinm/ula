<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(1,0)</definition>
  <definition>v2=(0,1)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <rectangle at="square" lower-left="(0,0)" dimensions="(1,1)"
               fill="lightgray" stroke="gray"/>
    <grid-axes/>
    <vector at="v1" v="v1" stroke="black"
            offset="(0,-2)" clear-background="yes">
      <m>\evec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="black" alignment="west"
            clear-background="yes" offset="(-1,0)">
      <m>\evec_2</m>
    </vector>
  </coordinates>

  <annotations text="The basis vectors e one and e two and the unit square that they form">
    <annotation ref="v1" text="The vector e one"/>
    <annotation ref="v2" text="The vector e two"/>
    <annotation ref="square"
                  text="The unit square formed by e one and e two"/>
  </annotations>
    
</diagram>
