<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(1,1)</definition>
  <definition>v2=(-1,1)</definition>
  <coordinates bbox="(-5.5,-5.5,5.5,5.5)">
    <transform>
      <change-basis basis="(v1, v2)"/>
      <grid at="grid" spacings="((-5,1,5),(-5,1,5))"
            stroke="lightgray" cliptobbox="yes"/>
      <axes at="axes" decorations="no"/>
    </transform>
    <axes at="std-axes" decorations="no" stroke="gray" thickness="1"/>
    <vector at="v1" v="v1" stroke="black" alignment="east" offset="(0,-3)">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="black" alignment="west">
      <m>\vvec_2</m>
    </vector>
    <vector at="x" v="(3,-1)" stroke="red" alignment="se">
      <m>\xvec</m>
    </vector>
    <vector at="Ax" v="(1,5)" stroke="gray" alignment="east">
      <m>A\xvec</m>
    </vector>
  </coordinates>

  <annotations text="v one and v two are eigenvectors that form a basis for R two.  As a result, we can determine the result of multiplying a linear combination of v one and v two by A.">
    <annotation ref="std-axes" text="The standard coordinate axes"/>
    <annotation ref="grid-group"
                text="The basis v one and v two define a new coordinate system">
      <annotation ref="v1" text="The vector v one"/>
      <annotation ref="v2" text="The vector v two"/>
      <annotation ref="axes"
                  text="A set of axes in the new coordinate system"/>
      <annotation ref="grid"
                  text="A grid representing linear combinations of v one and v two"/>
    </annotation>
    <annotation ref="x"
                text="The vector x is v one minus two v two."/>
    <annotation ref="Ax"
                text="The vector A times x is three v one plus two v two"/>
  </annotations>
    
</diagram>
