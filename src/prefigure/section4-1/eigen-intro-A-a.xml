<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(1,1)</definition>
  <definition>v2=(-1,1)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <transform>
      <change-basis basis="(v1, v2)"/>
      <rectangle at="square" lower-left="(0,0)" dimensions="(1,1)"
                 fill="lightgray" stroke="gray"/>
      <grid at="grid" cliptobbox="yes"/>
    </transform>
    <axes at="axes"/>
    <vector at="v1" v="v1" stroke="black" alignment="east"
            offset="(0,-2)" clear-background="yes">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="black" alignment="west"
            clear-background="yes" offset="(-1,0)">
      <m>\vvec_2</m>
    </vector>
  </coordinates>

  <annotations text="The unit square in the coordinate system defined by the eigenvectors.">
    <annotation ref="axes" text="The standard set of axes"/>
    <annotation ref="group"
                text="The coordinate system defined by the eigenvectors">
      <annotation ref="v1" text="The vector v one"/>
      <annotation ref="v2" text="The vector v two"/>
      <annotation ref="grid" text="The grid of linear combinations of v one and v two"/>
    </annotation>
    <annotation ref="square"
                text="The unit square in this coordinate system"/>
  </annotations>
</diagram>
