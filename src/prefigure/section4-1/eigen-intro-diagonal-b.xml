<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=3*(1,0)</definition>
  <definition>v2=-1*(0,1)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <rectangle at="square" lower-left="(0,-1)" dimensions="(3,1)"
               fill="#f77" stroke="gray"/>
    <grid-axes spacings="((-3,3,3), (-4,1,4))"/>
    <vector at="v1" v="v1" stroke="black" alignment="ne">
      <m>3\evec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="black" alignment="w"
            offset="(-1,1)" clear-background="yes">
      <m>-\evec_2</m>
    </vector>
  </coordinates>

  <annotations text="The result of multiplying the vectors e one and e two and the unit square by A">
    <annotation ref="v1" text="The vector three times e one"/>
    <annotation ref="v2" text="The vector negative one times e two"/>
    <annotation ref="square"
                  text="The result of mulitplying the unit square by A is a rectangle of width three and height one"/>
  </annotations>
    
</diagram>
