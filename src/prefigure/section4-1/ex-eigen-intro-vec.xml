<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <vector at="v2" v="2*(1,2)" stroke="blue" alignment="se">
      <m>2\vvec</m>
    </vector>
    <vector at="v" v="(1,2)" stroke="blue" alignment="se">
      <m>\vvec</m>
    </vector>
    <vector at="vminus" v="-(1,2)" stroke="blue" alignment="se">
      <m>-\vvec</m>
    </vector>
  </coordinates>
</diagram>
