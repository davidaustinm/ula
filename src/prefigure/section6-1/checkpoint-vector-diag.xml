<diagram xmlns="https://prefigure.org"
         dimensions="(300,300)" margins="5">
  <rectangle lower-left="(-5,-5)" dimensions="(310,310)"
             fill="white"/>
  <coordinates bbox="(-8,-8,8,8)">
    <grid-axes decorations="no" stroke="gray" thickness="0.5" />
    <axes decorations="no" arrows="2" thickness="1" />
    <definition>pa=(3.5,-1.2)</definition>
    <definition>pb=(1.2,3.2)</definition>
    <definition>pc=(-2.5,-1.5)</definition>
    <definition>pd=(-2.3,4.3)</definition>
    <vector at="u" v="(3,-1)" stroke="blue" alignment="se">
      <m>\uvec</m>
    </vector>
    <vector at="v" v="(1,3)" stroke="blue" alignment="ne">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="(-2,-1)" stroke="blue" alignment="sw">
      <m>\wvec</m>
    </vector>
    <vector at="x" v="(-2,4)" stroke="blue" alignment="nw">
      <m>\xvec</m>
    </vector>
  </coordinates>
  <annotations text="Four vectors, u, v, w, and x">
    <annotation ref="u"
                text="The vector u"/>
    <annotation ref="v"
                text="The vector v"/>
    <annotation ref="w"
                text="The vector w"/>
    <annotation ref="x"
                text="The vector x"/>
  </annotations>
</diagram>
