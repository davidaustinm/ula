<diagram xmlns="https://prefigure.org"
         dimensions="(350, 245)" margins="5">
  <read name="df" filename="clusters_data.csv"/>
  <definition>points=zip_lists(df["0"],df["1"])</definition>
  <coordinates bbox="(-3.5,-1.5,6.2,5.2)">
    <grid at="grid" spacings="((-4,1,6),(-2,1,5))"/>
    <axes at="axes" hlabels="(-2,2,4)" vlabels="(0,2,4)"/>
    <repeat at="points" parameter="p in points">
      <point p="p" size="2.5" fill="blue" stroke="none"/>
    </repeat>
  </coordinates>

  <annotations text="A collection of 177 two dimensional data points that form clusters">
    <annotation ref="grid"
                text="The coordinate grid and axes">
      <annotation ref="axes"/>
    </annotation>
    <annotation ref="points" text="177 data points"/>
  </annotations>
</diagram>
    

