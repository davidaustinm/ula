<diagram xmlns="https://prefigure.org"
         dimensions="(280, 280)" margins="5">
  <definition>v=(3,1)</definition>
  <definition>w=(3,2)</definition>
  <definition>u=(-2,3)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes at="axes"/>
    <vector at="v" v="v" fill="blue" stroke="blue">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="w" fill="blue" stroke="blue">
      <m>\wvec</m>
    </vector>
    <vector at="u" v="u" fill="blue" stroke="blue">
      <m>\uvec</m>
    </vector>
  </coordinates>

  <annotations text="Of the following three vectors, which are most similar?">
    <annotation ref="v"
                text="The vector v"/>
    <annotation ref="w"
                text="The vector w"/>
    <annotation ref="u"
                text="The vector u"/>
  </annotations>
</diagram>
