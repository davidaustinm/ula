<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(3,1)</definition>
  <definition>w=(2,3.5)</definition>
  <definition>diff=w-v</definition>
  <coordinates bbox="(-1,-1,4,4)">
    <axes at="axes" decorations="no"/>
    <vector at="v" v="v" stroke="black" alignment="se">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="w" stroke="black" alignment="nw">
      <m>\wvec</m>
    </vector>
    <vector at="diff" tail="v" v="diff" stroke="black" label-location="0.5"
            alignment="east">
      <m>\wvec-\vvec</m>
    </vector>
    <angle-marker at="angle" points="(v,(0,0),w)" stroke="black">
      <m>\theta</m>
    </angle-marker>
  </coordinates>

  <annotations text="The angle between two vectors can be found from the dot product">
    <annotation ref="axes"
                text="A set of horizontal and vertical axes"/>
    <annotation ref="triangle"
                text="The vectors v, w, and their difference form a triangle">
      <annotation ref="v"
                  text="The vector v"/>.
      <annotation ref="w"
                  text="The vector w"/>.
      <annotation ref="diff"
                  text="The vector w minus v"/>.
    </annotation>
    <annotation ref="angle"
                text="The angle betwen v and w is an angle in this triangle"/>
  </annotations>
</diagram>
