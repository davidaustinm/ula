<diagram xmlns="https://prefigure.org"
         dimensions="(350,260)" margins="(25,25,5,5)">
  <coordinates bbox="(0,0,9,4)">
    <grid at="grid-1" spacings="((0,1,9),(0,0.25,4))" stroke="#e6e6e6"/>
    <grid at="grid-2" spacings="((0,1,9),(0,0.5,4))" stroke="#cccccc"/>
    <axes at="axes" hlabels="(0,1,9)" vlabels="(0,1,3)" xlabel="k">
      <ylabel alignment="se">
        Objective
      </ylabel>
    </axes>
  </coordinates>

  <annotations text="A grid and axes for plotting the objective values">
    <annotation ref="grid-1"/>
    <annotation ref="grid-2"/>
    <annotation ref="axes"/>
  </annotations>
</diagram>
