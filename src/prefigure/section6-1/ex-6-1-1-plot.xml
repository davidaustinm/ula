<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(3,2)</definition>
  <definition>w=(-1,3)</definition>
  <definition>x=(-2,3)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid at="grid"/>
    <axes at="axes" xlabel="x" ylabel="y"/>
    <vector v="v" stroke="blue" alignment="ne">
      <m>\vvec</m>
    </vector>
    <vector v="w" stroke="blue" alignment="ne">
      <m>\wvec</m>
    </vector>
    <vector v="x" stroke="blue" alignment="nw">
      <m>\xvec</m>
    </vector>
  </coordinates>
</diagram>
