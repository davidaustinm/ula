<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="8">
  <coordinates bbox="(-2,-2,3,3)">
    <grid-axes spacings="((-2,1,3),(-2,1,3))"
          hlabels="(-2,1,3)" vlabels="(-2,1,3)"/>
    <point at="v1" p="(-2,1)" fill="#8080ff" stroke="black"
           alignment="se">
      <m>\vvec_1</m>
    </point>
    <point at="v2" p="(1,1)" fill="#8080ff" stroke="black"
           alignment="se">
      <m>\vvec_2</m>
    </point>
    <point at="v3" p="(1,2)" fill="#8080ff" stroke="black"
           alignment="nw">
      <m>\vvec_3</m>
    </point>
    <point at="v4" p="(3,2)" fill="#8080ff" stroke="black"
           alignment="nw">
      <m>\vvec_4</m>
    </point>
  </coordinates>
  <annotations text="A collection of four data points in the plane">
    <annotation ref="v1"
                text="The first data point v one"/>
    <annotation ref="v2"
                text="The second data point v two"/>
    <annotation ref="v3"
                text="The third data point v three"/>
    <annotation ref="v4"
                text="The fourth data point v four"/>
  </annotations>
</diagram>
