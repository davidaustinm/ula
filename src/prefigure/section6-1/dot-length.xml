<diagram xmlns="https://prefigure.org"
         dimensions="(300, 300)" margins="5">
  <coordinates bbox="(-1,-1,4,4)">
    <grid-axes decorations="no" spacings="((-1,1,4),(-1,1,4))"/>
    <line at="vertical" endpoints="((3,0),(3,2))" stroke="blue"/>
    <label at="vertical-label" anchor="(3,1)" alignment="east"
           offset="(3,0)">2</label>
    <line at="horizontal" endpoints="((0,0),(3,0))" stroke="blue"/>
    <label at="horizontal-label" anchor="(1.5,0)" alignment="south"
           offset="(0,-3)">3</label>
    <vector at="v" v="(3,2)" stroke="blue" alignment="nw"
            clear-background="yes">
      <m>\vvec=\twovec32</m>
    </vector>
    <label at="r-label" anchor="0.5*(3,2)" alignment="nw">
      <m>\len{\vvec}</m>
    </label>
  </coordinates>

  <annotations text="The length of the vector three two can be found from the dot product">
    <annotation ref="v" text="The length of the vector three two is the length of the hypotenuse of a right triangle">
      <annotation ref="r-label"/>
    </annotation>
    <annotation ref="horizontal"
                text="The horizontal length is three">
      <annotation ref="horizontal-label"/>
    </annotation>
    <annotation ref="vertical"
                text="The vertial length is two">
      <annotation ref="vertical-label"/>
    </annotation>
  </annotations>
</diagram>
      
