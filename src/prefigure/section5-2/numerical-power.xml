<diagram xmlns="https://prefigure.org"
         dimensions="(200, 200)" margins="5">
  <definition>t(x)=(2*x[0]+x[1], 2*x[1]+x[0])</definition>
  <definition>x = (1,0)</definition>
  <coordinates bbox="(-1,-1,8,8)">
    <define-shapes>
      <rectangle at="border" lower-left="(bbox[0],bbox[1])"
                 dimensions="(9,9)"/>
    </define-shapes>
    <grid at="grid" spacings="((-1,1,8),(-1,1,8))"/>
    <axes at="axes" decorations="no"/>
    <vector at="x0" v="x" stroke="red" alignment="se">
      <m>\xvec_0</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector at="x1" v="x" stroke="gray">
      <m>\xvec_1</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector at="x2" v="x" stroke="gray">
      <m>\xvec_2</m>
    </vector>
    <definition>x=t(x)</definition>
    <clip shape="border">
      <vector at="x3" v="x" stroke="gray" cliptobbox="yes"/>
    </clip>
  </coordinates>

  <annotations text="The vector x naught and the results of multiplying it repeatedly by the matrix A">
    <annotation ref="grid"
                text="The coordinate grid and axes">
      <annotation ref="axes"/>
    </annotation>
    <annotation ref="x0"
                text="The vector x naught is one zero"/>
    <annotation ref="x1"
                text="The vector x one obtained by multiplying x naught by A"/>
    <annotation ref="x2"
                text="The vector x two obtained by multiplying x one by A"/>
    <annotation ref="x3"
                text="The vector x three obtained by multiplying x two by A"/>
  </annotations>
</diagram>
