<diagram xmlns="https://prefigure.org"
         dimensions="(200, 200)" margins="5">
  <definition>t(x)=(1, (2*x[1]+x[0])/(2*x[0]+x[1]))</definition>
  <definition>x = (1,0)</definition>
  <coordinates bbox="(-1.5,-1.5,1.5,1.5)">
    <grid at="grid" spacings="((-1.5,0.5,1.5),(-1.5,0.5,1.5))"/>
    <axes at="axes" decorations="no"/>
    <rectangle center="(0,0)" dimensions="(2,2)"
               stroke="#555"/>
    <vector at="x0" v="x" stroke="red" alignment="se">
      <m>\xvec_0</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector at="x1" v="x" stroke="gray">
      <m>\xbar_1</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector at="x2" v="x" stroke="gray">
      <m>\xbar_2</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector at="x3" v="x" stroke="gray" cliptobbox="yes" alignment="east">
      <m>\xbar_3</m>
    </vector>
  </coordinates>

  <annotations text="The vector x naught and the results of multiplying it repeatedly by the matrix A and then scaling it">
    <annotation ref="grid"
                text="The coordinate grid and axes">
      <annotation ref="axes"/>
    </annotation>
    <annotation ref="x0"
                text="The vector x naught is one zero"/>
    <annotation ref="x1"
                text="The vector x one bar obtained by multiplying x naught by A and then scaling"/>
    <annotation ref="x2"
                text="The vector x two bar obtained by multiplying x one bar by A and then scaling"/>
    <annotation ref="x3"
                text="The vector x three bar obtained by multiplying x two bar by A and then scaling"/>
  </annotations>
</diagram>
