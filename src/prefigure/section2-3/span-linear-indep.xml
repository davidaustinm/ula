<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <definition>v=(2,0)</definition>
    <definition>w=(-1,1)</definition>
    <transform>
      <change-basis basis="(v,w)"/>
      <grid at="grid" spacings="((-5,1,5),(-5,1,5))" cliptobbox="yes"/>
    </transform>
    <axes/>
    <vector at="v" v="v" stroke="blue" alignment="ne">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="w" stroke="blue">
      <m>\wvec</m>
    </vector>
  </coordinates>

  <annotations text="The vectors v and w and some linear combinations they create.">
    <annotation ref="v" text="The vector v"/>
    <annotation ref="w" text="The vector w"/>
    <annotation ref="grid" text="A grid representing the linear combinations formed by v and w"/>
  </annotations>
</diagram>
