<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <definition>v=(-1,1)</definition>
  <definition>w=(2,-2)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <line at="line" endpoints="((0,0),v)" stroke="lightgray" infinite="yes"/>
    <axes/>
    <vector at="v" v="v" stroke="blue" alignment="sw">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="w" stroke="blue" alignment="ne">
      <m>\wvec</m>
    </vector>
  </coordinates>

  <annotations text="The vectors v and w and the linear combinations they create">
    <annotation ref="v" text="The vector v"/>
    <annotation ref="w" text="The vector w"/>
    <annotation ref="line"
                text="All the linear combinations they create lie on this line."/>
  </annotations>
</diagram>
