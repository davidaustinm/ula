<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(2,1)</definition>
  <definition>w=(2,4)</definition>
  <coordinates bbox="(-1,-1,5,5)">
    <grid at="grid" spacings="((-1,1,5),(-1,1,5))" thickness="1"/>
    <axes at="axes"  hlabels="(0,2,4)" vlabels="(0,2,4)"/>
    <line at="L"  endpoints="((0,0),v)" infinite="yes" stroke="blue"/>
    <vector at="v" v="v" stroke="black">
      <m>\wvec</m>
    </vector>
    <vector at="b" v="w" stroke="black">
      <m>\bvec</m>
    </vector>
    <label at="L-label" anchor="(5,2.5)"
           alignment="nw" offset="(-4,4)">
      <m>L</m>
    </label>
  </coordinates>

  <annotations text="A line L is defined by a vector w.  We would like to find the vector on the line that is closest to the vector b, which is not on the line">
    <annotation ref="grid" text="The coordinate grid and axes">
      <annotation ref="axes"/>
    </annotation>
    <annotation ref="L" text="The line L consists of all scalar multiples of w">
      <annotation ref="L-label"/>
      <annotation ref="v" text="The vector w"/>
    </annotation>
    <annotation ref="b" text="The vector b is not on the line"/>
  </annotations>
</diagram>
