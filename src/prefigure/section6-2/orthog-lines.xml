<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <axes at="axes" decorations="no" stroke="gray"/>
    <line at="line-1" endpoints="((0,0),(1,-2))" stroke="blue"
          infinite="yes"/>
    <line at="line-2" endpoints="((0,0),(2,1))" stroke="blue"
          infinite="yes"/>
    <vector at="v" v="(-1,2)" stroke="black">
      <m>\vvec</m>
    </vector>
    <label at="line-1-label" anchor="(1,-2)" alignment="ne" offset="(3,3)">
      <m>L</m>
    </label>
    <label at="line-2-label" anchor="(3,1.5)" alignment="nw" offset="(-3,3)">
      <m>L^\perp</m>
    </label>
  </coordinates>

  <annotations text="A line L in the plane and its orthogonal complement">
    <annotation ref="axes" text="A set of axes"/>
    <annotation ref="v" text="A vector v"/>
    <annotation ref="line-1" text="The line L defined by v">
      <annotation ref="line-1-label"/>
    </annotation>
    <annotation ref="line-2" text="The orthogonal complement to the line L">
      <annotation ref="line-2-label"/>
    </annotation>
  </annotations>
</diagram>
