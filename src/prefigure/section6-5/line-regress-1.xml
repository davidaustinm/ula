<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>f(x)=x-1/3</definition>
  <coordinates bbox="(-1,-1,4,4)">
    <grid-axes spacings="((-1,1,4),(-1,1,4))" 
               hlabels="(0,1,3)" vlabels="(0,1,3)"
               xlabel="x" ylabel="y"/>
    <definition>x=((1,1),(2,1),(3,3))</definition>
    <definition>ordinals=("first", "second", "third")</definition>
    <graph at="line" function="f"/>
    <repeat at="points" parameter="k=0..2"
            annotate="yes" text="The three data points and the vertical distances to the least squares line">
      <definition>p=x[k]</definition>
      <line at="vert" endpoints="(p, (p[0],f(p[0])))" stroke="red"
            annotate="yes" text="The vertical distance from the ${ordinals[k]} data point to the least squares line"/>
      <point at="p" p="x[k]" fill="#ff8080"
             annotate="yes" text="The ${ordinals[k]} data point"/>
    </repeat>
  </coordinates>

  <annotations text="The vertical distances from the data points to the least squares line">
    <annotation ref="line" text="The least squares line"/>
    <annotation ref="points"/>
  </annotations>
</diagram>
