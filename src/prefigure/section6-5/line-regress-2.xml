<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>f(x)=x-1/3</definition>
  <coordinates bbox="(-1,-1,4,4)">
    <grid-axes spacings="((-1,1,4),(-1,1,4))" 
               hlabels="(0,1,3)" vlabels="(0,1,3)"
               xlabel="x" ylabel="y"/>
    <graph at="line" function="f"/>
    <point at="p1" p="(1,1)" fill="#ff8080" stroke="black"/>
    <point at="p2" p="(2,1)" fill="#ff8080" stroke="black"/>
    <point at="p3" p="(3,3)" fill="#ff8080" stroke="black"/>
  </coordinates>
</diagram>
