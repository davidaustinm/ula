<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(1,1)</definition>
  <definition>v2=(0,2)</definition>
  <coordinates bbox="(-3,-3,3,3)">
    <grid-axes/>
    <vector at="v1" v="v1" stroke="blue" alignment="se">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="blue">
      <m>\vvec_2</m>
    </vector>
  </coordinates>

  <annotations text="Two vectors in the plane, v one and v two">
    <annotation ref="v1" text="The vector v one"/>
    <annotation ref="v2" text="The vector v two"/>
  </annotations>
</diagram>
