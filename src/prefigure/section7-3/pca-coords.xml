<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-3,-3,3,3)">
    <grid-axes decorations="no"/>
    <vector at="u1" v="(1,0)" stroke="black" alignment="se">
      <m>\uvec_1</m>
    </vector>
    <vector at="u2" v="(0,1)" stroke="black" alignment="nw">
      <m>\uvec_2</m>
    </vector>
    <vector at="x" v="(1.5,1.2)" stroke="black" alignment="north"
            offset="(0,4)" clear-background="yes">
      <m>\xhat=\twovec{\uvec_1\cdot\xvec}{\uvec_2\cdot\xvec}</m>
    </vector>
  </coordinates>
  <annotations text="The coordinates of the projected data point are computed by dot products">
    <annotation ref="u1" text="The basis vector u one"/>
    <annotation ref="u2" text="The basis vector u two"/>
    <annotation ref="x" text="A projected data point and its coordinate representation"/>
  </annotations>
</diagram>
