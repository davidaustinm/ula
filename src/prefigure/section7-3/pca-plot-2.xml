<diagram xmlns="https://prefigure.org"
         dimensions="(500, 300)" margins="(15,10,15,10)">
  <coordinates bbox="(-500,-300,500,300)">
    <grid-axes at="axes" hlabels="(-500,100,500)" vlabels="(-300,100,300)"
               spacings="((-500,100,500),(-300,100,300))"
               annotate="no"/>
  </coordinates>
  <annotations text="A coordinate grid and axes.  The horizontal coordinate runs from negative 500 to 500, and the vertical coordinate runs from negative 300 to 300">
    <annotation ref="axes"/>
  </annotations>
</diagram>
          
