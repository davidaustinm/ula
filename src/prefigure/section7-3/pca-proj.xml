<diagram xmlns="https://prefigure.org"
         dimensions="(300,240)" margins="5">
  <definition>v1=(0.5,0.15,-0.075)</definition>
  <definition>v2=(-0.1,0.5,0.1)</definition>
  <definition>n=(v1[1]*v2[2]-v1[2]*v2[1],v2[0]*v1[2]-v2[2]*v1[0],v1[0]*v2[1]-v1[1]*v2[0])</definition>
  <definition>a=1.5</definition>
  <definition>b=1.7</definition>
  <definition>bvec = 5.6*n + a*v1+ b*v2</definition>
  <definition>bhat=a*v1+b*v2</definition>

  <transform>
    <center/>
    <translate by="(0,-20)"/>
    <set-eye eye="(1,0.35,0.4)"/>
    <scale3d by="1.5*(70,70,70)"/>
    <definition>w=2.5</definition>
    <polygon at="plane"  points="(proj_2d(w*(v1+v2)),
                     proj_2d(w*(v1-v2)),
                     proj_2d(w*(-v1-v2)),
                     proj_2d(w*(-v1+v2)))"
             fill="#cccccc" stroke="none" closed="yes"
             cliptobbox="yes"/>

    <repeat at="grid" parameter="i=-2..2">
      <line endpoints="(proj_2d(-w*v1 + i*v2),
                       proj_2d(w*v1+i*v2))"
            stroke="#808080" thickness="1" cliptobbox="yes"/>
      <line endpoints="(proj_2d(i*v1 - w*v2),
                       proj_2d(i*v1+w*v2))"
            stroke="#808080" thickness="1" cliptobbox="yes"/>
    </repeat>

    <path at="axes" start="proj_2d(0,0,0)" stroke="black"
          thickness="1">
      <lineto point="proj_2d(0,0,1.3)"/>
      <moveto point="proj_2d(0,0,0)"/>
      <lineto point="proj_2d(2.2,0,0)"/>
      <moveto point="proj_2d(0,0,0)"/>
      <lineto point="proj_2d(0,1.4,0)"/>
    </path>

    <definition>bhat_2d = proj_2d(bvec)-proj_2d(bhat)</definition>
    <definition>marker_pt = proj_2d(bhat)-(-bhat_2d[1],bhat_2d[0])</definition>
    <definition>bperp = bvec-bhat</definition>
    <angle-marker at="angle"
                  points="(marker_pt,proj_2d(bhat),proj_2d(bvec))"/>
    <vector at="v1" v="proj_2d(v1)" stroke="black" thickness="2">
      <m>\uvec_1</m>
    </vector>
    <vector at="v2" v="proj_2d(v2)" stroke="black" alignment="nw"
            thickness="2">
      <m>\uvec_2</m>
    </vector>
    <vector at="b" v="proj_2d(bvec)" stroke="black" alignment="nw"
            offset="(0,-8)" thickness="2">
      <m>\xvec</m>
    </vector>
    <vector at="bhat" v="proj_2d(bhat)" stroke="black" alignment="sw"
            offset="(-3,0)" thickness="2">
      <m>\xhat</m>
    </vector>
    <vector at="bperp" v="proj_2d(bvec)-proj_2d(bhat)" tail="proj_2d(bhat)"
            stroke="black"/>
    
  </transform>
  <rectangle lower-left="(0,0)" dimensions="(bbox[2],bbox[3])"
             stroke="black"/>

  <annotations text="The projection of a data point x on W two is a three dimensional vector that is a linear combination of u one and u two">
    <annotation ref="axes" text="The three dimensional coordinate axes"/>
    <annotation ref="plane" text="The plane W two spanned by u one and u two">
      <annotation ref="v1" text="The vector u one"/>
      <annotation ref="v2" text="The vector u two"/>
      <annotation ref="grid" text="A grid of linear combinations of u one and u two"/>
    </annotation>
    <annotation ref="b" text="The vector x"/>
    <annotation ref="bhat" text="The vector x hat, which is the orthogonal projection of x onto W two"/>
    <annotation ref="bperp" text="The vector x minus x hat is perpendicular to the plane">
      <annotation ref="angle"/>
    </annotation>
  </annotations>
    
</diagram>
