<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>s=1/sqrt(2)</definition>
  <coordinates bbox="(-0.25,-0.25,1.25,1.25)">
    <grid-axes spacings="((-1.5,0.5,1.5),(-1.5,0.5,1.5))"
               hlabels="(0,1,1)" vlabels="(0,1,1)"/>
    <polygon at="triangle" points="((0,0),(s,0),(s,s))" stroke="black"
             thickness="2" closed="yes"/>
    <group at="vector">
      <vector at="v" v="(s,s)" stroke="blue">
        <m>T(\evec_1)</m>
      </vector>
      <label anchor="0.5*(s,s)" alignment="nw" offset="(-3,3)" scale="1.2">
        <m>1</m>
      </label>
    </group>
    <group at="vertical">
      <line endpoints="((s,0),(s,s))" endpoint-offset="(3,-3)"
            stroke="black"/>
      <label anchor="(s,s/2)" alignment="e"
             offset="(9,0)" scale="1.2">
        <m>1/\sqrt{2}</m>
      </label>
    </group>
    <group at="horizontal">
      <line endpoints="((0,0),(s,0))" endpoint-offset="(3,-3)"
            stroke="black"/>
      <label anchor="(s/2,0)" alignment="south" offset="(6,-5)" scale="1.2">
        <m>1/\sqrt{2}</m>
      </label>
    </group>
  </coordinates>

  <annotations text="The rotated vector T of e one forms an isoceles right triangle whose hypotenus has length one">
    <annotation ref="vector"
                text="The vector T of e one has length one and makes a 45 degree angle with the horizontal axis"/>
    <annotation ref="horizontal"
                text="The horizontal leg of the right triangle has length one over the square root of two"/>
    <annotation ref="vertical"
                text="The vertical leg of the right triangle has length one over the square root of two"/>
  </annotations>
</diagram>
