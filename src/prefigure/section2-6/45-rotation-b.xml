<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <transform>
      <rotate by="45"/>
      <vector at="v" v="(3,1)" stroke="blue" alignment="ne">
        <m>T(\xvec)</m>
      </vector>
    </transform>
  </coordinates>

  <annotations text="The result of rotating the vector x by 45 degrees">
    <annotation ref="v"
                text="The vector T of x, which is obtained by rotating x by 45 degrees"/>
  </annotations>
</diagram>
