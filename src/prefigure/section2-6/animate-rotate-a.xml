<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>f(t)=(0.25*sin(t), 2-0.5*cos(t))</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <transform>
      <rotate by="45"/>
      <path at="char" start="(0.5,0)" stroke="blue">
        <lineto point="(0,0.5)"/>
        <lineto point="(-0.5,0)"/>
        <moveto point="(0.5,1.5)"/>
        <lineto point="(-0.5,0.5)"/>
        <moveto point="(0,0.5)"/>
        <lineto point="(0,1.5)"/>
        <parametric-curve function="f" domain="(0,2*pi)"/>
      </path>
    </transform>
  </coordinates>

  <annotations text="The character has been rotated by 45 degrees">
    <annotation ref="char"
                text="The rotated character"/>
  </annotations>
</diagram>
