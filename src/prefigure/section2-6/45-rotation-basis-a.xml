<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>e1=(1,0)</definition>
  <definition>e2=(0,1)</definition>
  <coordinates bbox="(-1.25,-1.25,1.25,1.25)">
    <grid-axes spacings="((-1.5,0.5,1.5),(-1.5,0.5,1.5))"
               hlabels="(-1,1,1)" vlabels="(-1,1,1)"/>
    <vector at="e1" v="e1" stroke="blue" alignment="nw">
      <m>\evec_1</m>
    </vector>
    <vector at="e2" v="e2" stroke="blue" alignment="ne">
      <m>\evec_2</m>
    </vector>
  </coordinates>

  <annotations text="The standard vectors e one and e two">
    <annotation ref="e1"
                text="The vector e one whose components are one zero"/>
    <annotation ref="e2"
                text="The vector e two whose components are zero one"/>
  </annotations>
</diagram>
