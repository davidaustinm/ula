
<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>c=1.8</definition>
  <definition>v=(2,1)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <transform>
      <rotate by="45"/>
      <vector at="cv" v="c*v" stroke="blue" alignment="se">
        <m>T(c\vvec)</m>
      </vector>
      <vector at="v" v="v" stroke="gray" alignment="se">
        <m>T(\vvec)</m>
      </vector>
    </transform>
  </coordinates>

  <annotations text="A vector v and the scalar multiple c times v both rotated by 45 degrees">
    <annotation ref="v"
                text="The vector v rotated by 45 degrees to obtain T of v"/>
    <annotation ref="cv"
                text="The scalar multiple c times v rotated by 45 degrees to obtain T of c times v"/>
  </annotations>
</diagram>

