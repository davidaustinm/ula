
<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>c=1.8</definition>
  <definition>v=(2,1)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <vector at="cv" v="c*v" stroke="blue" alignment="n">
      <m>c\vvec</m>
    </vector>
    <vector at="v" v="v" stroke="gray" alignment="se">
      <m>\vvec</m>
    </vector>
  </coordinates>

  <annotations text="A vector v and a scalar multiple c times v">
    <annotation ref="v"
                text="The vector v"/>
    <annotation ref="cv"
                text="The scalar multiple c times v lies on the same line as v"/>
  </annotations>
</diagram>

