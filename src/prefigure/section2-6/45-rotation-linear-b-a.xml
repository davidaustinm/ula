<diagram xmlns="https://prefigure.org"
         dimensions="(300, 300)" margins="5">
  <definition>v=(2,1)</definition>
  <definition>w=(-1,3)</definition>
  <coordinates bbox="(-5,-5,5,5)">
    <grid-axes decorations="no" spacings="((-5,1,5),(-5,1,5))"/>
    <vector at="v" v="v" stroke="gray">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="w" stroke="gray" alignment="sw">
      <m>\wvec</m>
    </vector>
    <vector at="v-trans" v="v" tail="w" stroke="gray"/>
    <vector at="w-trans" v="w" tail="v" stroke="gray"/>
    <vector at="sum" v="v+w" fill="blue" stroke="blue" alignment="east"
            offset="(4,-7)">
      <m>\vvec+\wvec</m>
    </vector>
  </coordinates>

  <annotations text="The parallelogram representing the sum of two vectors v and w">
    <annotation ref="group"
                text="The parallelogram formed by v and w">
      <annotation ref="v-sides"
                  text="Opposite sides of the parallelogram formed by v">
        <annotation ref="v"/>
        <annotation ref="v-trans"/>
      </annotation>
      <annotation ref="w-sides"
                  text="Opposite sides of the parallelogram formed by w">
        <annotation ref="w"/>
        <annotation ref="w-trans"/>
      </annotation>
    </annotation>
    <annotation ref="sum"
                text="The sum v plus w is the diagonal of the parallelogram"/>
  </annotations>
</diagram>
