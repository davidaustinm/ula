<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>e1=(1,0)</definition>
  <definition>e2=(0,1)</definition>
  <coordinates bbox="(-1.25,-1.25,1.25,1.25)">
    <grid-axes spacings="((-1.5,0.5,1.5),(-1.5,0.5,1.5))"
               hlabels="(-1,1,1)" vlabels="(-1,1,1)"/>
    <transform>
      <rotate by="45"/>
      <vector at="e1" v="e1" stroke="blue" alignment="n">
        <m>T(\evec_1)</m>
      </vector>
      <vector at="e2" v="e2" stroke="blue" alignment="n">
        <m>T(\evec_2)</m>
      </vector>
    </transform>
  </coordinates>

  <annotations text="The matrix transformation T rotates the standard vectors e one and e two by 45 degrees">
    <annotation ref="e1"
                text="The vector T of e one is obtained by rotating e one by 45 degrees"/>
    <annotation ref="e2"
                text="The vector T of e two is obtained by rotating e two by 45 degrees"/>
  </annotations>
</diagram>
