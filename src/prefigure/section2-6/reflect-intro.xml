<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <vector at="v" v="(3,2)" stroke="blue" alignment="nw">
      <m>\xvec</m>
    </vector>
    <vector at="Tv" v="(3,-2)" stroke="blue" alignment="sw">
      <m>T(\xvec)</m>
    </vector>
  </coordinates>

  <annotations text="A two dimensional vector x and its reflection in the horizontal axis">
    <annotation ref="v"
                text="The vector x"/>
    <annotation ref="Tv"
                text="The vector T of x, which is obtained by reflecting x in the horizontal axis."/>
  </annotations>
</diagram>
