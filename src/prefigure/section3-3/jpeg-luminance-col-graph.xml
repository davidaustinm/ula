<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="(45,30,5,5)">
  <definition>values=(176,181,165,139,131,131,140,150)</definition>
  <definition>strings=['first','second','third','fourth','fifth','sixth','seventh','eighth']</definition>
  <coordinates bbox="(0,0,7,255)">
    <axes at="axes" hlabels="(0,1,7)" vlabels="(0,50,250)">
      <ylabel alignment="se" offset="(3,0)"><m>\xvec</m></ylabel>
    </axes>
    <repeat at="components" parameter="k=0..7"
            annotate="yes" text="The components of x">
      <point at="point" p="(k, values[k])" fill="blue"
             annotate="yes"
             text="The luminance of the ${strings[k]} component is ${values[k]}"/>
    </repeat>
  </coordinates>

  <annotations text="A graphical representation of the vector x consisting of lumiance values in the first column of the eight by eight block of pixels">
    <annotation ref="axes" text="A set of axes"/>
    <annotaiton ref="components"/>
  </annotations>
</diagram>
