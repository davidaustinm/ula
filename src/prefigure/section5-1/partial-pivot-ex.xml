<diagram xmlns="https://prefigure.org"
         dimensions="(200, 200)" margins="(25,25,5,10)">
  <coordinates bbox="(0,0,2,2)">
    <grid-axes spacings="((0,0.5,2),(0,0.5,2))"
               hlabels="(0,1,2)" vlabels="(0,1,2)"/>
    <line at="horizontal" endpoints="((0,1),(1,1))" infinite="yes"
          stroke="blue"/>
    <line at="slope" endpoints="((0,2),(1,1))" infinite="yes"
          stroke="blue"/>
  </coordinates>

  <annotations text="Two lines, one horizontal and the other with slope negative one, intersect at the point one one">
    <annotation ref="horizontal"
                text="The horizontal line"/>
    <annotation ref="slope"
                text="The line with slope negative one"/>
  </annotations>
</diagram>
    
