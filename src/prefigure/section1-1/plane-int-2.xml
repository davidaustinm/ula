<diagram xmlns="https://prefigure.org"
         dimensions="(200, 180)" margins="5">
  <transform>
    <set-eye eye="(0.5,0.8,0.9)"/>
    <center/>
    <scale3d by="1.1*(50,70,100)"/>
    <transform>
      <scale3d by="(1,1,0.75)"/>
      <polygon at="plane-1-1" points="(proj_2d(0.5,-0.65,-0.13), proj_2d(0.5,0.65,-0.325), proj_2d(0,0,0))" 
               fill="#c7c7c7" stroke="#999999" closed="yes"
               miterlimit="1"/>
    </transform>
    <polygon at="plane-2-1" points="(proj_2d(-0.5,-0.65,-0.13), proj_2d(-0.5,0.65,0.13), proj_2d(0.5,0.65,0.13), proj_2d(0.5,-0.65,-0.13))" 
             fill="#b3b3b3" stroke="#999999" closed="yes"
             miterlimit="1"/>
    <transform>
      <scale3d by="(1,1,0.75)"/>
      <polygon at="plane-1-2" points="(proj_2d(-0.5,-0.65,0.325), proj_2d(0.5,-0.65,-0.13), proj_2d(0,0,0))" 
               fill="#c7c7c7" stroke="#999999" closed="yes"
               miterlimit="1"/>
      <path at="line-1-2-1" start="proj_2d(0.5,-0.65,-0.13)" stroke="blue">
        <lineto point="proj_2d(0,0,0)"/>
      </path>
    </transform>
    <polygon at="plane-3" points="(proj_2d(-0.5,-0.65,0.325), proj_2d(-0.5,0.65,-0.325), proj_2d(0.5,0.65,-0.325), proj_2d(0.5,-0.65,0.325))" 
             fill="#d9d9d9" stroke="#b3b3b3" closed="yes"
             miterlimit="1"/>
    <transform>
      <scale3d by="(1,1,0.75)"/>
      <polygon at="plane-1-3" points="(proj_2d(-0.5,0.65,0.13), proj_2d(0.5,0.65,-0.325), proj_2d(0,0,0))" 
               fill="#c7c7c7" stroke="#999999" closed="yes"
               miterlimit="1"/>
      <path at="line-1-3-1" start="proj_2d(0.5,0.65,-0.325)" stroke="blue">
        <lineto point="proj_2d(0,0,0)"/>
      </path>
    </transform>
    <polygon at="plane-2-2" points="(proj_2d(-0.5,0,0), proj_2d(-0.5,0.65,0.13), proj_2d(0.5,0.65,0.13), proj_2d(0.5,0,0))" 
             fill="#b3b3b3" stroke="#999999" closed="yes"
             miterlimit="1"/>
    <transform>
      <scale3d by="(1,1,0.75)"/>
      <polygon at="plane-1-4" points="(proj_2d(-0.5,-0.65,0.325), proj_2d(-0.5,0.65,0.13), proj_2d(0,0,0))" 
               fill="#c7c7c7" stroke="#999999" closed="yes"
               miterlimit="1"/>
      <path at="line-1-2-2" start="proj_2d(-0.5,0.65,0.13)" stroke="blue">
        <lineto point="proj_2d(0,0,0)"/>
      </path>
      <path at="line-1-3-2" start="proj_2d(-0.5,-0.65,0.325)" stroke="blue">
        <lineto point="proj_2d(0,0,0)"/>
      </path>
    </transform>
    <path at="line-2-3" start="proj_2d(0.5,0,0)" stroke="blue">
      <lineto point="proj_2d(0,0,0)"/>
    </path>
    <point at="point" p="proj_2d(0,0,0)" size="2.5"/>
  </transform>

  <annotations text="This three dimensional figure shows three planes that intersect in a single point.">
    <annotation ref="plane-1"
                text="The first plane">
      <annotation ref="plane-1-1"/>
      <annotation ref="plane-1-2"/>
      <annotation ref="plane-1-3"/>
      <annotation ref="plane-1-4"/>
    </annotation>
    <annotation ref="plane-2" text="The second plane">
      <annotation ref="plane-2-1"/>
      <annotation ref="plane-2-2"/>
    </annotation>
    <annotation ref="plane-3" text="The third plane"/>
    <annotation ref="line-1-2"
                text="The intersection of the first two planes">
      <annotation ref="line-1-2-1"/>
      <annotation ref="line-1-2-2"/>
    </annotation>
    <annotation ref="line-1-3"
                text="The intersection of the first and third planes">
      <annotation ref="line-1-3-1"/>
      <annotation ref="line-1-3-2"/>
    </annotation>
    <annotation ref="line-2-3"
                text="The intersection of the second and third planes"/>
    <annotation ref="point"
                text="The point of intersection of the three planes"/>
  </annotations>
</diagram>

