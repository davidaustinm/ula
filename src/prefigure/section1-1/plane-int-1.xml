<diagram xmlns="https://prefigure.org"
         dimensions="(200, 180)">
  <transform>
    <set-eye eye="(0.5,0.8,0.8)"/>
    <center/>
    <scale3d by="(50,70,70)"/>
    <polygon at="plane-1-1" points="(proj_2d(-0.5,-0.65,-0.13), proj_2d(-0.5,0.65,0.13), proj_2d(0.5,0.65,0.13), proj_2d(0.5,-0.65,-0.13))" 
          fill="#b3b3b3" stroke="#999999" closed="yes"/>
    <polygon at="plane-2" points="(proj_2d(-0.5,-0.65,0.325), proj_2d(-0.5,0.65,-0.325), proj_2d(0.5,0.65,-0.325), proj_2d(0.5,-0.65,0.325))" fill="#d9d9d9" stroke="#b3b3b3" closed="yes"/>
    <polygon at="plane-1-2" points="(proj_2d(-0.5,0,0), proj_2d(-0.5,0.65,0.13), proj_2d(0.5,0.65,0.13), proj_2d(0.5,0,0))" fill="#b3b3b3" stroke="#999999" closed="yes"/>
    <path at="line" start="proj_2d(0.5,0,0)" stroke="blue" thickness="2">
      <lineto point="proj_2d(-0.5,0,0)"/>
    </path>
  </transform>

  <annotations text="In this three dimensional figure, two planes intersect in a line">
    <annotation ref="plane-1"
    text="The first plane">
      <annotation ref="plane-1-1"/>
      <annotation ref="plane-1-2"/>
    </annotation>
    <annotation ref="plane-2"
      text="The second plane"/>
    <annotation ref="line"
      text="The line of intersection"/>
  </annotations>
</diagram>
