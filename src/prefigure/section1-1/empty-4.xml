<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid at="grid"/>
    <axes at="axes" xlabel="x" ylabel="y"/>
  </coordinates>
  <annotations text="An empty coordinate grid and axes for plotting">
    <annotation ref="grid" text="A one by one coordinate grid"/>
    <annotation ref="axes" text="A set of axes"/>
  </annotations>
</diagram>
