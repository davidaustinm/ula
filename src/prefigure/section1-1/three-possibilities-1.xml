<diagram xmlns="https://prefigure.org"
         dimensions="(150, 150)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <line at="line1" endpoints="((0,-1),(1,0))" stroke="blue" infinite="yes"/>
  </coordinates>

  <annotations text="A single line in the plane.">
    <annotation ref="line1" 
                text="The line passes through zero minus one and has slope one"/>
  </annotations>
</diagram>
