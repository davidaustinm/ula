<diagram xmlns="https://prefigure.org"
         dimensions="(200,180)" margins="5">
  <transform>
    <set-eye eye="(0.7,0.8,0.5)"/>
    <center/>
    <translate by="(0,-40)"/>
    <scale3d by="1.45*(50,60,70)"/>
    <polygon at="plane" points="(proj_2d(-0.5,-0.65,0.8), proj_2d(-0.5,0.65,0), proj_2d(0.5,0.65,0), proj_2d(0.5,-0.65,0.8))" 
            fill="#d9d9d9" stroke="#b3b3b3" closed="yes"/>
  </transform>

  <annotations text="A plane in three dimensions">
    <annotation ref="plane"/>
  </annotations>
</diagram>
