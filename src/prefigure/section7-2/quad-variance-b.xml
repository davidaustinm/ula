<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>points=[(-3,-3),(2,1),(1,2)]</definition>
  <definition>ordinals=["first", "second", "third"]</definition>
  <definition>v1=(1,-1)</definition>
  <definition>proj(x)=dot(x,v1)/dot(v1,v1)*v1</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes/>
    <line at="line" endpoints="((0,0),v1)" infinite="yes"
          stroke="gray"/>
    <repeat at="data" parameter="k=0..2"
            annotate="yes" text="The three data points projected onto the line">
      <definition>p=proj(points[k])</definition>
      <line at="proj-line" endpoints="(p,points[k])"
            stroke="#8080ff"/>
      <point at="point" p="points[k]" fill="blue"
             annotate="yes" text="The ${ordinals[k]} data point"/>
      <point at="p-point" p="p" fill="lightgray"
             annotate="yes" text="The ${ordinals[k]} projected data point"/>
    </repeat>
  </coordinates>
  <annotations text="A two dimensional dataset with three points projected onto a line">
    <annotation ref="line" text="The line in the direction one negative one"/>
    <annotation ref="data"/>
  </annotations>
</diagram>
