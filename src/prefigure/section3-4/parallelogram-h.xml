<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v1=(1,2)</definition>
  <definition>v2=(-1,-2)</definition>
  <coordinates bbox="(-3,-3,3,3)">
    <define-shapes>
      <polygon at="poly" points="((0,0),v1,v1+v2,v2)" closed="yes"/>
    </define-shapes>
    <shape at="poly-fill" shape="poly" fill="lightgray"/>
    <grid at="grid" spacings="((-3,1,3),(-3,1,3))" stroke="gray"
          thickness="1"/>
    <axes at="axes"/>
    <shape at="poly-stroke" shape="poly" stroke="black"/>
  </coordinates>

  <annotations text="A parallelogram whose vertices lie on a line">
    <annotation ref="poly-fill"
                text="The parallelogram">
      <annotation ref="poly-stroke"/>
    </annotation>
    <annotation ref="grid"
                text="A one by one grid"/>
  </annotations>
  
</diagram>
