<diagram xmlns="https://prefigure.org"
         dimensions="(200, 200)" margins="5">
  <definition>v1=(1,0)</definition>
  <definition>v2=(0,1)</definition>
  <coordinates bbox="(-2.5,-2.5,2.5,2.5)">
    <grid at="grid" spacings="((-3,1,3),(-3,1,3))"/>
    <polygon at="poly" points="((0,0),v1,v1+v2,v2)"
             fill="#8080ff" stroke="none" closed="yes"/>
    <axes hlabels="(-2,2,2)" vlabels="(-2,2,2)"/>
    <vector at="v1" v="v1" fill="black" stroke="black">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" fill="black" stroke="black" alignment="nw">
      <m>\vvec_2</m>
    </vector>
  </coordinates>

  <annotations text="The parallelogram formed by the columns of the identity matrix">
    <annotation ref="grid"
                text="A one by one grid"/>
    <annotation ref="v1"
                text="The vector v one, which is the first column of the identity matrix"/>
    <annotation ref="v2"
                text="The vector v two, which is the second column of the identity matrix"/>
    <annotation ref="poly"
                text="The parallelogram formed by these vectors is a one by one square"/>
  </annotations>
</diagram>
