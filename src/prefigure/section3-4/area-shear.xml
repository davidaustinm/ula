<diagram xmlns="https://prefigure.org"
         dimensions="(200, 120)" margins="5">
  <coordinates bbox="(-2,-1,5,4)">
    <axes decorations="no"/>
    <line at="horizontal" endpoints="((0,3),(1,3))"
          infinite="yes" stroke="#808080"/>
    <vector at="v" v="(3,0)" stroke="blue" alignment="se">
      <m>\vvec</m>
    </vector>
    <vector at="w1" v="(-1,3)" stroke="blue" alignment="nw">
      <m>\wvec_1</m>
    </vector>
    <vector at="w2" v="(2,3)" stroke="blue" alignment="ne">
      <m>\wvec_2</m>
    </vector>
  </coordinates>

  <annotations text="A vector v and two other vectors w one and w two used to form parallelograms">
    <annotation ref="v"
                text="The vector v is horizontal"/>
    <annotation ref="group"
                text="The vectors w one and w two end on the same horizontal line">
      <annotation ref="horizontal"
                  text="A horizontal line"/>
      <annotation ref="w1"
                  text="The vector w one"/>
      <annotation ref="w2"
                  text="The vector w two"/>
    </annotation>
  </annotations>
</diagram>
