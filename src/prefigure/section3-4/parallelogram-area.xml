<diagram xmlns="https://prefigure.org"
         dimensions="(200, 80)" margins="(5,25,5,5)">
  <definition>v1=(6,0)</definition>
  <definition>v2=(4,4)</definition>
  <coordinates bbox="(0,0,10,4)">
    <polygon at="poly" points="((0,0),v1,v1+v2,v2)" closed="yes"
             stroke="black" fill="lightgray" thickness="2"
             cliptobbox="no"/>
    <line at="h" endpoints="(v2,(v2[0],0))" stroke="black"/>
    <label at="h-label" anchor="(v2[0],v2[0]/2)" alignment="east">
      <m>h</m>
    </label>
    <line at="b" endpoints="((0,0),v1)" stroke="black"
          endpoint-offsets="(3,-3)"/>
    <label at="b-label" anchor="(v1[0]/2,0)" alignment="south">
      <m>b</m>
    </label>
  </coordinates>

  <annotations text="The area of a parallelogram is the product of its height and base">
    <annotation ref="poly"
                text="A parallelogram"/>
    <annotation ref="h"
                text="The height is the length of a perpendicular line segment joining two opposite sides">
      <annotation ref="h-label"/>
    </annotation>
    <annotation ref="b"
                text="The base is the length of one of those opposite sides">
      <annotation ref="b-label"/>
    </annotation>
  </annotations>
</diagram>
