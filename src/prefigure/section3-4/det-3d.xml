<diagram xmlns="https://prefigure.org"
         dimensions="(200, 200)" margins="5">
  <definition>v1=(3,2,-0.5)</definition>
  <definition>v2=(-0.7,2,0)</definition>
  <definition>v3=(0,1,3.5)</definition>
  <transform>
    <center/>
    <translate by="(-28,-25)"/>
    <set-eye eye="(1,0.5,0.5)"/>
    <scale3d by="1.25*(23,23,23)"/>

    <path at="axes" start="proj_2d(0,0,0)" stroke="#555">
      <lineto point="proj_2d(4,0,0)"/>
      <moveto point="proj_2d(0,0,0)"/>
      <lineto point="proj_2d(0,4,0)"/>
      <moveto point="proj_2d(0,0,0)"/>
      <lineto point="proj_2d(0,0,4)"/>
    </path>

    <polygon at="bottom"
             points="(proj_2d(v1),proj_2d(v1+v2),proj_2d(v1+v2+v3),proj_2d(v1+v3))"
             closed="yes" fill="#ddd" stroke="#777"
             miterlimit="1" opacity="0.7"/>
    <polygon at="left"
             points="(proj_2d(v1),proj_2d(v1+v3),proj_2d(v3),proj_2d(0,0,0))"
             closed="yes" fill="#bbb" stroke="#777"
             miterlimit="1" opacity="0.7"/>
    <polygon at="back"
             points="(proj_2d(v3),proj_2d(v1+v3),proj_2d(v1+v2+v3),proj_2d(v2+v3))"
             closed="yes" fill="#aaa" stroke="#555"
             miterlimit="1" opacity="0.7"/>
    <polygon at="front"
             points="(proj_2d(v1),proj_2d(v1+v2),proj_2d(v2),proj_2d(0,0,0))"
             closed="yes" fill="#aaa" stroke="#555"
             miterlimit="1" opacity="0.5"/>
    <polygon at="right"
             points="(proj_2d(v2),proj_2d(v2+v3),proj_2d(v3),proj_2d(0,0,0))"
             closed="yes" fill="#aaa" stroke="#555"
             miterlimit="1" opacity="0.5"/>
    <polygon at="top"
             points="(proj_2d(v2),proj_2d(v2+v1),proj_2d(v1+v2+v3),proj_2d(v2+v3))"
             closed="yes" fill="#aaa" stroke="#555"
             miterlimit="1" opacity="0.5"/>

    <vector at="v1" v="proj_2d(v1)">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="proj_2d(v2)" alignment="east">
      <m>\vvec_2</m>
    </vector>
    <vector at="v3" v="proj_2d(v3)" alignment="n">
      <m>\vvec_3</m>
    </vector>
  </transform>

  <annotations text="The absolute value of the determinant is the volume of the parallelpiped defined by the columns of the matrix">
    <annotation ref="v-group"
                text="The columns of the matrix, v one, v two, and v three">
      <annotation ref="v1" text="The vector v one"/>
      <annotation ref="v2" text="The vector v two"/>
      <annotation ref="v3" text="The vector v three"/>
    </annotation>
    <annotation ref="volume"
                text="The parallelpiped defined by the vectors">
      <annotation ref="back"/>
      <annotation ref="left"/>
      <annotation ref="bottom"/>
      <annotation ref="top"/>
      <annotation ref="front"/>
      <annotation ref="right"/>
    </annotation>
  </annotations>
</diagram>
  
