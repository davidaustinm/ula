<diagram xmlns="https://prefigure.org"
         dimensions="(150,150)" margins="5">
  <definition>v1=(2,0)</definition>
  <definition>v2=(0,3)</definition>
  <coordinates bbox="(-1,-1,4,4)">
    <define-shapes>
      <polygon at="poly" points="((0,0),v1,v1+v2,v2)" closed="yes"/>
    </define-shapes>
    <shape at="poly-fill" shape="poly" fill="lightgray"/>
    <grid at="grid" spacings="((-1,1,4),(-1,1,4))" stroke="gray"
          thickness="1"/>
    <axes at="axes"/>
    <shape at="poly-stroke" shape="poly" stroke="black"/>
  </coordinates>

  <annotations text="A parallelogram with vertices at the origin, two zero, two three, and zero three">
    <annotation ref="poly-fill"
                text="The parallelogram">
      <annotation ref="poly-stroke"/>
    </annotation>
    <annotation ref="grid"
                text="A one by one grid"/>
  </annotations>
  
</diagram>
