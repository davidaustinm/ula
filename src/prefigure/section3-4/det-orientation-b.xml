<diagram xmlns="https://prefigure.org"
         dimensions="(160, 160)" margins="5">
  <definition>w=(3,1)</definition>
  <definition>v=(1.5,3)</definition>
  <coordinates bbox="(-1,-1,4,4)">
    <axes decorations="no"/>
    <angle-marker at="angle" points="(v,(0,0),w)" stroke="black"/>
    <vector v="v" stroke="blue">
      <m>\vvec_1</m>
    </vector>
    <vector v="w" stroke="blue">
      <m>\vvec_2</m>
    </vector>
  </coordinates>

  <annotations text="A negatively oriented basis for R two">
    <annotation ref="v"
                text="The vector v one"/>
    <annotation ref="w"
                text="The vector v two"/>
    <annotation ref="angle"
                text="The angle obtained by rotating v one counterclockwise toward v two"/>
  </annotations>
</diagram>
