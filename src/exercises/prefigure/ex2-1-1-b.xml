<diagram xmlns="https://prefigure.org"
         dimensions="(350,350)" margins="5">
  <definition>v=(1,-1)</definition>
  <definition>w=(3,1)</definition>
  <coordinates bbox="(-6,-6,6,6)">
    <grid-axes spacings="((-6,1,6),(-6,1,6))" clear-background="yes">
      <xlabel alignment="nw"><m>x</m></xlabel>
      <ylabel alignment="se"><m>y</m></ylabel>
    </grid-axes>
    <vector v="v" stroke="blue">
      <m>\vvec</m>
    </vector>
    <vector v="w" stroke="blue">
      <m>\wvec</m>
    </vector>
    <vector v="-3*v" stroke="black"/>
    <vector v="2*w" stroke="black"/>
    <vector v="v+2" stroke="black"/>
    <vector v="v-2" stroke="black"/>
  </coordinates>
</diagram>
