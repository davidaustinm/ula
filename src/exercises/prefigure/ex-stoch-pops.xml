<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-2,-2,6,5)">
    <network directed="yes" labels="yes" node-style="box"
             node-fill="white" node-size="20" node-thickness="2"
             arrows="middle">
      <node at="1" p="(2,3)" loop-orientation="135">U</node>
      <node at="2" p="(4,0)" loop-orientation="315">S</node>
      <node at="3" p="(0,0)" loop-orientation="225">R</node>
      <edge vertices="(1,2)" offset="(-3,10)">0.07</edge>
      <edge vertices="(2,1)">0.08</edge>
      <edge vertices="(3,1)" offset="(-8,-7)">0.08</edge>
      <edge vertices="(1,3)">0.05</edge>
      <edge vertices="(2,3)" offset="(12,0)">0.06</edge>
      <edge vertices="(3,2)">0.07</edge>
      <edge vertices="(1,1)" loop-scale="(0.6,0.6)">0.88</edge>
      <edge vertices="(2,2)" loop-scale="(0.6,0.6)">0.86</edge>
      <edge vertices="(3,3)" loop-scale="(0.6,0.6)">0.85</edge>
    </network>
  </coordinates>

  <annotations text="This diagram describes the percentages that move between urban, suburaban and rural communities">
    <annotation ref="node-1"
                text="The urban population">
      <annotation ref="edge-1-2"
                  text="7 percent of the people will move to a suburban community"/>
      <annotation ref="edge-1-3"
                  text="5 percent of the people will move to a rural community"/>
      <annotation ref="loop-1"
                  text="Eighty eight percent of the people will stay in their urban community"/>
    </annotation>
    <annotation ref="node-2"
                text="The suburban community">
      <annotation ref="edge-2-1"
                  text="8 percent of the people will move to an urban community"/>
      <annotation ref="edge-2-3"
                  text="6 percent of the people will move to a rural community"/>
      <annotation ref="loop-2"
                  text="Eight six percent will stay in their suburban community"/>
    </annotation>
    <annotation ref="node-3"
                text="The rural community">
      <annotation ref="edge-3-1"
                  text="8 percent of the people will move to an urban community"/>
      <annotation ref="edge-3-2"
                  text="7 percent of the people will move to a suburban community"/>
      <annotation ref="loop-3"
                  text="Eighty five percent will stay in their rural community"/>
    </annotation>
  </annotations>
</diagram>
