<diagram xmlns="https://prefigure.org"
         dimensions="(240, 90)" margins="5">
  <coordinates bbox="(0,-1,8,2)">
    <rectangle at="box-1" lower-left="(0,0)" fill="lightgray"
               stroke="black"/>
    <rectangle at="box-2" lower-left="(1,0)" fill="white"
               stroke="black"/>
    <rectangle at="box-3" lower-left="(2,0)" fill="lightgray"
               stroke="black"/>
    <rectangle at="box-4" lower-left="(3,0)" fill="lightgray"
               stroke="black"/>
    <rectangle at="box-5" lower-left="(4,0)" fill="lightgray"
               stroke="black"/>
    <rectangle at="box-6" lower-left="(5,0)" fill="lightgray"
               stroke="black"/>
    <rectangle at="box-7" lower-left="(6,0)" fill="white"
               stroke="black"/>
    <rectangle at="box-8" lower-left="(7,0)" fill="lightgray"
               stroke="black"/>
    <label at="label-1" anchor="(0.5,0.5)" font-size="20"
           alignment="c">1</label>
    <label at="label-3" anchor="(2.5,0.5)" font-size="20"
           alignment="c">2</label>
    <label at="label-4" anchor="(3.5,0.5)" font-size="20"
           alignment="c">3</label>
    <label at="label-5" anchor="(4.5,0.5)" font-size="20"
           alignment="c">4</label>
    <label at="label-6" anchor="(5.5,0.5)" font-size="20"
           alignment="c">5</label>
    <label at="label-8" anchor="(7.5,0.5)" font-size="20"
           alignment="c">6</label>
    <path at="path-2-5" start="(1.5,0)" stroke="black" mid-arrow="yes">
      <quadratic-bezier controls="((2.0,-0.75),(3,-0.75))"/>
      <quadratic-bezier controls="((4,-0.75),(4.5,0))"/>
    </path>
    <path at="path-7-1" start="(6.5,1)" stroke="black" mid-arrow="yes">
      <quadratic-bezier controls="((5.5,1.75),(3.5,1.75))"/>
      <quadratic-bezier controls="((1.5,1.75),(0.5,1))"/>
    </path>
  </coordinates>

  <annotations text="Our version of Chutes and Ladders has eight positions with one ladder and one chute">
    <annotation ref="box-1"
                text="This position labeled one is an ordinary position">
      <annotation ref="label-1"/>
    </annotation>
    <annotation ref="box-2"
                text="If we land on this position, we take the ladder three positions to the right to position four">
      <annotation ref="path-2-5"/>
    </annotation>
    <annotation ref="box-3"
                text="This position labeled two is an ordinary position">
      <annotation ref="label-3"/>
    </annotation>
    <annotation ref="box-4"
                text="This position labeled three is an ordinary position">
      <annotation ref="label-4"/>
    </annotation>
    <annotation ref="box-5"
                text="This position labeled four is an ordinary position">
      <annotation ref="label-5"/>
    </annotation>
    <annotation ref="box-6"
                text="This position labeled five is an ordinary position">
      <annotation ref="label-6"/>
    </annotation>
    <annotation ref="box-7"
                text="If we land on this position, we take the chute back down to position one">
      <annotation ref="path-7-1"/>
    </annotation>
    <annotation ref="box-8"
                text="This position labeled six is an ordinary position">
      <annotation ref="label-8"/>
    </annotation>
  </annotations>
    
</diagram>
  
