<diagram xmlns="https://prefigure.org"
         dimensions="(200, 150)" margins="(30,5,5,5)">
  <definition>points=((1,1),(2,1),(3,-1),(4,-1))</definition>
  <coordinates bbox="(0,-1.25,4.5,1.25)">
    <axes at="axes">
      <ylabel alignment="se">
        <m>\vvec_2</m>
      </ylabel>
    </axes>
    <repeat at="data" parameter="p in points" annotate="yes"
            text="The components of the basis vector">
      <point at="point" p="p" fill="blue" annotate="yes"
             text="The point ${p[0]} ${p[1]}"/>
    </repeat>
  </coordinates>
  <annotations text="The first two components of the next basis vector are one and the last two are negative one">
    <annotation ref="axes" text="A set of axes"/>
    <annotation ref="data"/>
  </annotations>
</diagram>
  
               
    
