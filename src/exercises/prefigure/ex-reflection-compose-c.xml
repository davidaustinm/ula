<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(-0.75,1.5)</definition>
  <definition>Rv=(1.628,-0.403)</definition>
  <definition>theta=degrees(atan2(1.25,1))</definition>
  <coordinates bbox="(-2,-2,2,2)">
    <axes at="axes" decorations="no"/>
    <transform>
      <rotate by="-theta"/>
      <line at="line" endpoints="((0,0),(1,1.25))" infinite="yes"
            stroke="black" thickness="3"/>
      <label at="line-label" anchor="(1.5,1.5*1.25)" alignment="se">
        <m>L</m>
      </label>
    </transform>

    <transform>
      <scale by="(1,-1)"/>
      <rotate by="-theta"/>
      <vector at="v" v="v" stroke="blue" alignment="ne">
        <m>S(R(\xvec))</m>
      </vector>
    </transform>
  </coordinates>

  <annotations text="The vector R of x is next reflected in the horizontal axis">
    <annotation ref="axes"
                text="The horizontal and vertical axes"/>
    <annotation ref="v"
                text="The rotated vector R of x is reflected in the horizontal axis to obtain S of R of x"/>
  </annotations>
</diagram>
