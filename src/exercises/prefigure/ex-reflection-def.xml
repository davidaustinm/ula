<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(-0.75,1.5)</definition>
  <definition>Rv=(1.628,-0.403)</definition>
  <coordinates bbox="(-2,-2,2,2)">
    <axes at="axes" decorations="no"/>
    <line at="line" endpoints="((0,0),(1,1.25))" infinite="yes"
          stroke="black"/>
    <label at="line-label" anchor="(1.5,1.5*1.25)" alignment="se">
      <m>L_\theta</m>
    </label>
    <angle-marker at="angle" points="((2,0),(0,0),(1,1.25))">
      <m>\theta</m>
    </angle-marker>
    <vector at="v" v="v" stroke="blue" alignment="west">
      <m>\xvec</m>
    </vector>
    <vector at="Rv" v="Rv" stroke="blue" alignment="sw">
      <m>T(\xvec)</m>
    </vector>
  </coordinates>

  <annotations text="A vector x, a line L, and the vector obtained by reflecting x in L">
    <annotation ref="axes"
                text="The horizontal and vertical axes"/>
    <annotation ref="line"
                text="The line L"/>
    <annotation ref="angle"
                text="The line makes an angle theta with the positive horizontal axis"/>
    <annotation ref="v"
                text="The vector x"/>
    <annotation ref="Rv"
                text="The vector T of x obtained by reflecting x in the line"/>
  </annotations>
                
        
</diagram>
