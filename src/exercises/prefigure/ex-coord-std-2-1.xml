<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid at="grid"/>
    <axes decorations="no"/>
    <vector at="e1" v="(1,0)" stroke="#808080">
      <m>\evec_1</m>
    </vector>
    <vector at="e2" v="(0,1)" stroke="#808080">
      <m>\evec_2</m>
    </vector>
    <vector at="comb" v="(2,-3)" fill="black" stroke="black">
      <m>(2,-3)</m>
    </vector>
  </coordinates>
  <annotations text="Two vector e one and e two and the linear combination 2 times e one plus negative three times e two">
    <annotation ref="grid"
                text="The standard coordinate grid"/>
    <annotation ref="e1"
                text="The vector e one"/>
    <annotation ref="e2"
                text="The vector e two"/>
    <annotation ref="comb"
                text="The linear combination of e one and e two"/>
  </annotations>
                
</diagram>
