<diagram xmlns="https://prefigure.org"
         dimensions="(300, 300)" margins="5">
  <definition>p=(2,3)</definition>
  <definition>x=(4,2)</definition>
  <definition>n=(1,2)</definition>
  <coordinates bbox="(-1,-1,6,6)">
    <axes at="axes" decorations="no"/>
    <line at="line" endpoints="(p,x)" stroke="blue" infinite="yes"/>
    <vector at="p" v="p" stroke="black" alignment="nw" label-location="0.8">
      <m>\pvec</m>
    </vector>
    <vector at="x" v="x" stroke="black" alignment="ne">
      <m>\xvec</m>
    </vector>
    <vector at="n" tail="p" v="n" stroke="black" alignment="se">
      <m>\nvec</m>
    </vector>
  </coordinates>

  <annotations text="A line, a point on the line, and a vector perpendicular to the line">
    <annotation ref="axes" text="A set of axes"/>
    <annotation ref="line" text="A line in the plane"/>
    <annotation ref="p" text="A point p on the line"/>
    <annotation ref="n" text="A vector n perdicular to the line"/>
    <annotation ref="x" text="Another point x on the line"/>
  </annotations>
</diagram>
