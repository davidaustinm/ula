<diagram xmlns="https://prefigure.org"
         dimensions="(250, 200)" margins="(30,5,5,5)">
  <definition>j=2</definition>
  <definition>f(t)=sin((2*t-1)*j*pi/8)</definition>
  <definition>strings=['first','second','third','fourth','fifth','sixth','seventh','eighth']</definition>
  <coordinates bbox="(0,-1.25,4,1.25)">
    <axes at="axes" hlabels="(0,1,4)" vlabels="(-1,1,1)">
      <ylabel alignment="se"><m>\vvec_{${j}}</m></ylabel>
    </axes>
    <graph at="graph" function="f" stroke="gray"/>
    <repeat at="components" parameter="k=0..3"
            annotate="yes" text="The components of the basis vector">
      <point at="point" p="(k+1, f(k+1))" fill="blue"
             annotate="yes" text="The ${strings[k]} component"/>
    </repeat>
  </coordinates>

  <annotations text="The second basis vector v two">
    <annotation ref="axes" text="A set of axes to represent the values of the components"/>
    <annotation ref="graph"
                text="The graph of the function that describes the values of the components"/>
    <annotation ref="components"/>
  </annotations>
</diagram>
