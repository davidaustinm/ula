<diagram xmlns="https://prefigure.org"
         dimensions="(300,300)" margins="5">
  <definition>v1=(2,-0.5)</definition>
  <definition>v2=(-1,1.5)</definition>
  <definition>b=-3*v1-3*v2</definition>
  <coordinates bbox="(-5.5,-5.5,5.5,5.5)">
    <transform>
      <change-basis basis="((2,-0.5),(-1,1.5))"/>
      <grid at="grid" spacings="((-5,1,5),(-5,1,5))" cliptobbox="yes"/>
    </transform>
    <axes decorations="no"/>
    <vector at="v1" v="v1" stroke="#808080" alignment="se"
            clear-background="yes">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="#808080" alignment="nw"
            clear-background="yes">
      <m>\vvec_2</m>
    </vector>
    <vector at="b" v="b" stroke="black"
            clear-background="yes">
      <m>\bvec</m>
    </vector>
  </coordinates>
  <annotations text="The matrix A has columns v one and v two, which are shown here, along with a grid representing their linear combinations.">
    <annotation ref="v1" text="The vector v one"/>
    <annotation ref="v2" text="The vector v two"/>
    <annotation ref="grid"
                text="A grid representing the linear combinations of v one and v two"/>
    <annotation ref="b" text="The vector b"/>
  </annotations>
</diagram>
