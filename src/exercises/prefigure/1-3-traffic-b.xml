<diagram xmlns="https://prefigure.org"
    dimensions="(350, 130)" margins="10">
  <coordinates bbox="(0,-0.1,3,1.1)">
    <network directed="yes" labeled="no" node-size="3" node-fill="black"
            arrows="middle">
      <node at="1" p="(0,1)"/>
      <node at="2" p="(1,1)"/>
      <node at="3" p="(2,1)"/>
      <node at="4" p="(3,1)"/>
      <node at="5" p="(0,0)"/>
      <node at="6" p="(1,0)"/>
      <node at="7" p="(2,0)"/>
      <node at="8" p="(3,0)"/>
      <edge vertices="(1,2)" alignment="n" offset="(0,3)"><m>x</m></edge>
      <edge vertices="(2,3)" alignment="n" offset="(0,3)">100</edge>
      <edge vertices="(3,4)" alignment="n" offset="(0,3)">260</edge>
      <edge vertices="(5,6)" alignment="n" offset="(0,3)">250</edge>
      <edge vertices="(6,7)" alignment="n" offset="(0,3)"><m>z</m></edge>
      <edge vertices="(7,8)" alignment="n" offset="(0,3)">390</edge>
      <edge vertices="(2,6)" offset="(-2,0)"><m>y</m></edge>
      <edge vertices="(7,3)" offset="(2,0)"><m>w</m></edge>
    </network>
  </coordinates>

  <annotations text="A network of one way streets with the number of cars per hour traveling on each street.">
    <annotation ref="node-2"
                text="The first intersection">
      <annotation ref="edge-1-2"
                  text="The number of cars entering from the left is x"/>
      <annotation ref="edge-2-3"
                  text="The number of cars leaving to the right is 100"/>
      <annotaiton ref="edge-2-6"
                  text="The number of cars leaving downward is y"/>
    </annotation>
        <annotation ref="node-6"
                text="The second intersection">
      <annotation ref="edge-2-6"
                  text="The number of cars entering from above is y"/>
      <annotation ref="edge-5-6"
                  text="The number of cars entering from the left is 250"/>
      <annotaiton ref="edge-6-7"
                  text="The number of cars leaving to the right is z"/>
    </annotation>
        <annotation ref="node-3"
                text="The third intersection">
      <annotation ref="edge-2-3"
                  text="The number of cars entering from the left is 100"/>
      <annotation ref="edge-7-3"
                  text="The number of cars entering from below is w"/>
      <annotaiton ref="edge-3-4"
                  text="The number of cars leaving to the right is 260"/>
    </annotation>
        <annotation ref="node-7"
                text="The fourth intersection">
      <annotation ref="edge-6-7"
                  text="The number of cars entering from the left is z"/>
      <annotation ref="edge-7-3"
                  text="The number of cars leaving upward is w"/>
      <annotaiton ref="edge-7-8"
                  text="The number of cars leaving to the right is 390"/>
    </annotation>
  </annotations>
</diagram>
