<diagram xmlns="https://prefigure.org"
         dimensions="(300, 300)" margins="5">
  <definition>v1=(2,1)</definition>
  <definition>v2=(-1,1)</definition>
  <coordinates bbox="(-7,-7,7,7)">
    <axes at="std-axes" stroke="#808080" decorations="no" thickness="1"/>
    <transform>
      <change-basis basis="((2,1),(-1,1))"/>
      <grid at="grid" spacings="((-7,1,7),(-7,1,7))" cliptobbox="yes"/>
      <axes at="axes" stroke="black" decorations="no" cliptobbox="yes"/>
    </transform>
    <vector at="v1" v="v1" stroke="black">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="black">
      <m>\vvec_2</m>
    </vector>
    <vector at="x" v="(0,-3)" stroke="red">
      <m>\xvec</m>
    </vector>
  </coordinates>

  <annotations text="A basis of eigenvectors v one and v two, the coordinate system they define, and a vector x">
    <annotation ref="group"
                text="The coordinate system defined by the eigenvectors">
      <annotation ref="v1" text="The eigenvector v one"/>
      <annotation ref="v2" text="The eigenvector v two"/>
      <annotation ref="grid" text="The coordinate system they define">
        <annotation ref="axes"/>
      </annotation>
    </annotation>
    <annotation ref="x" text="The vector x"/>
  </annotations>
</diagram>
