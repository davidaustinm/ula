<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <definition>v=(2,1)</definition>
  <definition>w=(1,2)</definition>
  <coordinates bbox="(-5,-5,5,5)">
    <transform>
      <change-basis basis="(v,w)"/>
      <grid at="grid" spacings="((-4,1,4),(-4,1,4))" cliptobbox="yes"/>
    </transform>
    <axes decorations="no"/>
    <vector at="e1" v="v" stroke="#808080">
      <m>\vvec_1</m>
    </vector>
    <vector at="e2" v="w" stroke="#808080">
      <m>\vvec_2</m>
    </vector>
    <vector at="comb" v="2*v-3*w" fill="black" stroke="black">
      <m>\{2,-3\}</m>
    </vector>
  </coordinates>

  <annotations text="Two vector v one and v two and the linear combination 2 times v one plus negative three times v two">
    <annotation ref="grid"
                text="The coordinate grid formed by v one and v two"/>
    <annotation ref="e1"
                text="The vector v one"/>
    <annotation ref="e2"
                text="The vector v two"/>
    <annotation ref="comb"
                text="The linear combination of v one and v two"/>
  </annotations>
</diagram>
