<diagram xmlns="https://prefigure.org"
         dimensions="(300, 300)" margins="5">
  <definition>v1=(-2,2)</definition>
  <definition>v2=(2,1)</definition>
  <coordinates bbox="(-6,-6,6,6)">
    <grid-axes spacings="((-6,1,6),(-6,1,6))"
               hlabels="(-4,2,4)" vlabels="(-4,2,4)" annotate="no"/>
    <grid at="grid"  basis="(v1,v2)" stroke="#808080"/>
    <vector at="v1" v="v1" stroke="black" alignment="nw"
            clear-background="yes">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="(2,1)" stroke="black" alignment="n"
            clear-background="yes">
      <m>\vvec_2</m>
    </vector>
  </coordinates>

  <annotations text="A pair of two dimensional vectors and a grid formed by the linear combinations they create">
    <annotation ref="v1"
                text="The vector v one"/>
    <annotation ref="v2"
                text="The vector v two"/>
    <annotation ref="grid"
                text="The linear combinations formed by v one and v two"/>
  </annotations>
</diagram>
