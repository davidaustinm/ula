<diagram xmlns="https://prefigure.org"
         dimensions="(280,280)" margins="5">
  <definition>v=(3,1.6)</definition>
  <definition>w=(-1,2)</definition>
  <coordinates bbox="(-10,-10,10,10)">
    <axes decorations="no"/>
    <transform>
      <change-basis basis="(v,w)"/>
      <grid at="grid" spacings="((-4,1,4),(-5,1,5))" cliptobbox="yes"/>
    </transform>
    <vector at="v" v="v" stroke="#808080">
      <m>\vvec</m>
    </vector>
    <vector at="w" v="w" stroke="#808080">
      <m>\wvec</m>
    </vector>
    <point at="p" p="-v" size="2" fill="black" stroke="none">
      <m>p</m>
    </point>
    <point at="q" p="3*w" size="2" fill="black" stroke="none">
      <m>q</m>
    </point>
    <point at="r" p="2*v+3*w" size="2" fill="black" stroke="none">
      <m>r</m>
    </point>
    <point at="s" p="2*v-3*w" size="2" fill="black" stroke="none">
      <m>s</m>
    </point>
    <point at="t" p="-3*v-2*w" size="2" fill="black" stroke="none">
      <m>t</m>
    </point>
    <point at="u" p="-2*v+0.5*w" size="2" fill="black" stroke="none">
      <m>u</m>
    </point>
    <point at="v-point" p="3.5*v+1.5*w" size="2" fill="black" stroke="none">
      <m>v</m>
    </point>
  </coordinates>
  <annotations text="Linear combinations of two vectors v and w">
    <annnotation ref="combs"
                 text="The vectors v and w and the skewed grid formed by their linear combinations">
      <annotation ref="v" text="The vector v"/>
      <annotation ref="w" text="The vector w"/>
      <annotation ref="grid" text="The grid formed by their linear combinations"/>
    </annnotation>
    <annotation ref="p" text="The point p"/>
    <annotation ref="q" text="The point q"/>
    <annotation ref="r" text="The point r"/>
    <annotation ref="s" text="The point s"/>
    <annotation ref="t" text="The point t"/>
    <annotation ref="u" text="The point u"/>
    <annotation ref="v-point" text="The point v"/>
  </annotations>
</diagram>
