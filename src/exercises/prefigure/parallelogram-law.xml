<diagram xmlns="https://prefigure.org"
         dimensions="(300, 300)" margins="5">
  <definition>v=(4,2)</definition>
  <definition>w=(1.5,3)</definition>
  <coordinates bbox="(-1,-1,6,6)">
    <axes decorations="no"/>
    <polygon points="((0,0),v,v+w,w)" stroke="black" closed="yes"/>
    <vector v="v" stroke="black" label-location="0.5" alignment="se">
      <m>\vvec</m>
    </vector>
    <vector v="w" stroke="black" label-location="0.5" alignment="nw">
      <m>\wvec</m>
    </vector>
    <vector v="v+w" stroke="black" alignment="nw">
      <m>\vvec+\wvec</m>
    </vector>
    <vector tail="v" v="w-v" stroke="black" alignment="nw" offset="(3,0)">
      <m>\wvec-\vvec</m>
    </vector>
  </coordinates>
</diagram>
