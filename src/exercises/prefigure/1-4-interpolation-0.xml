<diagram xmlns="https://prefigure.org"
         dimensions="(250,250)" margins="5">
  <coordinates bbox="(-1,-1,4,4)">
    <grid at="grid" spacings="((-1,1,4),(-1,1,4))"/>
    <axes at="axes" hlabels="(0,1,4)" vlabels="(0,1,4)"/>
    <point at="point-1" p="(0,2)" fill="blue"/>
    <point at="point-2" p="(1,3)" fill="blue"/>
    <point at="point-3" p="(2,0)" fill="blue"/>
    <point at="point-4" p="(3,1)" fill="blue"/>
  </coordinates>

  <annotations text="Four points in the coordinate plane">
    <annotation ref="grid-axes"
                text="A coordinate grid and set of axes">
      <annotation ref="grid"/>
      <annotation ref="axes"/>
    </annotation>
    <annotation ref="points"
                text="Four points in the plane">
      <annotation ref="point-1"/>
      <annotation ref="point-2"/>
      <annotation ref="point-3"/>
      <annotation ref="point-4"/>
    </annotation>
  </annotations>
</diagram>
