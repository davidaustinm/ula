<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(-0.75,1.5)</definition>
  <definition>Rv=(1.628,-0.403)</definition>
  <definition>theta=degrees(atan2(1.5,1))</definition>
  <coordinates bbox="(-2,-2,2,2)">
    <axes at="axes" decorations="no"/>
    <line at="line" endpoints="((0,0),(1,1.25))" infinite="yes"
          stroke="black" thickness="3"/>
    <label at="line-label" anchor="(1.5,1.5*1.25)" alignment="se">
      <m>L</m>
    </label>

    <vector at="Rv" v="Rv" stroke="blue" alignment="sw">
        <m>T(S(R(\xvec)))</m>
    </vector>
  </coordinates>

  <annotations text="Finally, we rotate the line and reflected axis counterclockwise by an angle theta">
    <annotation ref="axes"
                text="The horizontal and vertical axes"/>
    <annotation ref="line"
                text="The line L">
      <annotation ref="line-label"/>
    </annotation>
    <annotation ref="Rv"
                text="The final vector T of S of R of x"/>
  </annotations>
</diagram>
