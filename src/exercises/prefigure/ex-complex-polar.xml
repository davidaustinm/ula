<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(1,1.5)</definition>
  <coordinates bbox="(-1,-1,2,2)">
    <axes at="axes" decorations="no"/>
    <angle-marker at="angle" points="((2,0),(0,0),v)">
      <m>\theta</m>
    </angle-marker>
    <vector at="v" tail="(0,0)" v="v" stroke="blue" alignment="se">
      <m>\twovec{a}{b}</m>
    </vector>
    <label at="r" anchor="0.5*v" alignment="nw">
      <m>r</m>
    </label>
  </coordinates>

  <annotations text="A two dimensional vector represented in polar coordinates">
    <annotation ref="axes"
                text="The horizontal and vertical axes"/>
    <annotation ref="v"
                text="A two dimensional vector whose components are a and b"/>
    <annotation ref="angle"
                text="The measure of the angle v makes with the positive horizontal axis is theta"/>
    <annotation ref="r"
                text="The length of the vector is r"/>
  </annotations>
</diagram>
