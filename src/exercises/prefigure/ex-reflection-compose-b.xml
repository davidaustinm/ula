<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>v=(-0.75,1.5)</definition>
  <definition>Rv=(1.628,-0.403)</definition>
  <definition>theta=degrees(atan2(1.25,1))</definition>
  <coordinates bbox="(-2,-2,2,2)">
    <axes at="axes" decorations="no"/>
    <transform>
      <rotate by="-theta"/>
      <line at="line" endpoints="((0,0),(1,1.25))" infinite="yes"
            stroke="black" thickness="3"/>
      <vector at="v" v="v" stroke="blue" alignment="ne">
        <m>R(\xvec)</m>
      </vector>
    </transform>
  </coordinates>

  <annotations text="The vector x and line L have been rotated clockwise by an angle theta">
    <annotation ref="axes"
                text="The horizontal and vertical axes"/>
    <annotation ref="line"
                text="The rotated line L now lies on the horizontal axis"/>
    <annotation ref="v"
                text="The rotated vector is R of x"/>
  </annotations>
</diagram>
