<diagram xmlns="https://prefigure.org"
         dimensions="(240, 30)" margins="5">
  <coordinates bbox="(0,0,8,1)">
    <repeat at="boxes" parameter="k=1..8"
            annotate="yes"
            text="The eight positions are arranged from left to right">
      <rectangle at="box" lower-left="(k-1,0)" dimensions="(1,1)"
                 fill="lightgray" stroke="black"
                 annotate="yes"
                 text="The position labeled ${k}"/>
      <label at="box-label" anchor="(k-0.5,0.5)" alignment="c"
             font-size="20">
        ${k}
      </label>
    </repeat>
  </coordinates>

  <annotations text="Our version of Chutes and Ladders has eight positions">
    <annotation ref="boxes"/>
  </annotations>
    
</diagram>
  
