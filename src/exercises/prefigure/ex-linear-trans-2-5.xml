<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-3,-3,3,3)">
    <definition>v1=(2,1)</definition>
    <definition>v2=(-1,1)</definition>
    <definition>v3=(-1,-2)</definition>
    <grid-axes/>
    <vector at="v1" v="v1" stroke="blue" alignment="se">
      <m>\vvec_1</m>
    </vector>
    <vector at="v2" v="v2" stroke="blue" alignment="nw">
      <m>\vvec_2</m>
    </vector>
    <vector at="v3" v="v3" stroke="blue" alignment="nw">
      <m>\vvec_3</m>
    </vector>
  </coordinates>

  <annotations text="This two dimensional diagram contains three vectors:  v one, v two, and v three">
    <annotation ref="v1"
                text="The vector v one has components two one"/>
    <annotation ref="v2"
                text="The vector v two has components negative one one"/>
    <annotation ref="v3"
                text="The vector v three has components negative one negative two"/>
  </annotations>
</diagram>
    
