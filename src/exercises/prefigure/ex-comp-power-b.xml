<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>t(p)=(-0.8*p[1], 0.8*p[0])</definition>
  <definition>x=(3,0)</definition>
  <coordinates bbox="(-4,-4,4,4)">
    <grid at="grid"/>
    <axes at="axes" decorations="no"/>
    <definition>x=t(x)</definition>
    <vector v="x" alignment="nw" stroke="blue">
      <m>A\xvec</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector v="x" alignment="sw" stroke="blue">
      <m>A^2\xvec</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector v="x" alignment="se" stroke="blue">
      <m>A^3\xvec</m>
    </vector>
    <definition>x=t(x)</definition>
    <vector v="x" alignment="ne" stroke="blue">
      <m>A^4\xvec</m>
    </vector>
  </coordinates>
</diagram>
