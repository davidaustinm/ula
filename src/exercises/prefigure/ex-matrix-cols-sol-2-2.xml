<diagram xmlns="https://prefigure.org"
         dimensions="(300,300)" margins="10">
  <definition>v1=(2,-0.5)</definition>
  <definition>v2=(-1,1.5)</definition>
  <definition>b=-3*v1-3*v2</definition>
  <coordinates bbox="(-5.5,-5.5,5.5,5.5)">
    <transform>
      <change-basis basis="((2,-0.5),(-1,1.5))"/>
      <grid at="grid" spacings="((-5,1,5),(-5,1,5))" cliptobbox="yes"/>
    </transform>
    <axes decorations="no"/>
    <vector at="v1" v="v1" stroke="#808080" alignment="se"
            clear-background="yes">
      <m>A\twovec10</m>
    </vector>
    <vector at="v2" v="v2" stroke="#808080" alignment="nw"
            clear-background="yes">
      <m>\vvec_2</m>
    </vector>
    <vector at="b" v="b" stroke="black"
            clear-background="yes">
      <m>\bvec</m>
    </vector>
    <vector v="2*v1+3*v2" stroke="black" alignment="east"
            clear-background="yes">
      <m>A\twovec23</m>
    </vector>
    <vector v="-3*v2" stroke="black" alignment="east"
            clear-background="yes">
      <m>A\twovec0{-3}</m>
    </vector>
  </coordinates>
</diagram>
