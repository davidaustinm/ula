<diagram xmlns="https://prefigure.org"
         dimensions="(200, 75)" margins="5">
  <coordinates bbox="(-0.5,-0.25,1.5,1)">
    <network directed="yes" labels="yes" node-fill="white"
             node-size="15" edge-spread="20" node-style="box"
             arrows="middle">
      <node at="1" p="(0,0)" font-size="15" loop-orientation="135">P</node>
      <node at="2" p="(1,0)" font-size="15" loop-orientation="45">Q</node>
      <edge vertices="(1,2)"/>
      <edge vertices="(2,1)"/>
      <edge vertices="(1,1)" loop-scale="(0.6,0.6)"/>
      <edge vertices="(2,2)" loop-scale="(0.6,0.6)"/>
    </network>
  </coordinates>

  <annotations text="A sample transition diagram with unspecified transition probabilities">
    <annotation ref="node-1"
                text="This is state P from which we can transition to Q or stay at P">
      <annotation ref="loop-1"/>
      <annotation ref="edge-1-2"/>
    </annotation>
    <annotation ref="node-2"
                text="This is state Q from which we can transition to P or stay at Q">
      <annotation ref="edge-2-1"/>
      <annotation ref="loop-2"/>
    </annotation>
  </annotations>
</diagram>
            
