<diagram xmlns="https://prefigure.org"
         dimensions="(350,350)" margins="5">
  <definition>v1=(1,0.5)</definition>
  <definition>v2=(-1,0.5)</definition>
  <coordinates bbox="(-6,-6,6,6)">
    <axes at="std-axes" decorations="no" thickness="1"/>
    <repeat at="grid" parameter="k=-10..10">
      <line endpoints="(k*v1,k*v1+v2)" stroke="lightgray" infinite="yes"/>
      <line endpoints="(k*v2,k*v2+v1)" stroke="lightgray" infinite="yes"/>
    </repeat>
    <group at="axes">
      <line endpoints="((0,0),v1)" stroke="black" infinite="yes"/>
      <line endpoints="((0,0),v2)" stroke="black" infinite="yes"/>
    </group>
  </coordinates>

  <annotations text="A grid and axes defined by the eigenvectors">
    <annotation ref="std-axes"/>
    <annotation ref="grid"/>
    <annotation ref="axes"/>
  </annotations>
</diagram>
