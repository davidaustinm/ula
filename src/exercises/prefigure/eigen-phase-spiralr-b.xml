<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <definition>stretch = 1.5</definition>
  <definition>rotate = 0.4</definition>
  <definition>x = [[1.5,0], [2,0], [3,0], [4,0], [5,0]]</definition>
  <definition>iters = [0,1,2,3,4]</definition>
  <definition>v1=(1,0.5)</definition>
  <definition>v2=(-1,1)</definition>
  <coordinates bbox="(-6,-6,6,6)">
    <axes at="std-axes" decorations="no"/>
    <repeat at="grid" parameter="i=-6..6">
      <line endpoints="(i*v1,i*v1+v2)" stroke="lightgray" infinite="yes"/>
      <line endpoints="(i*v2,i*v2+v1)" stroke="lightgray" infinite="yes"/>
    </repeat>
    <transform>
      <change-basis basis="(v1, v2)"/>
      <repeat at="curves" parameter="p in x"
              annotate="yes" text="A set of trajectories">
        <repeat at="permute" parameter="k=0..3"
                annotate="yes">
          <definition>l=length(p)</definition>
          <definition>angle=atan2(p[1],p[0])</definition>
          <definition>f(t)=l*stretch**t*(cos(angle+t*rotate),sin(angle+t*rotate))</definition>
          <parametric-curve function="f" stroke="blue" domain="(-10,10)"
                            arrows="1" arrow-location="1.6"
                            cliptobbox="yes"/>
          <repeat at="iterates" parameter="k in iters"
                  annotate="yes">
            <point p="f(k)" size="2.5" fill="black" stroke="none"
                   cliptobbox="yes"/>
          </repeat>
          <definition>p=(-p[1],p[0])</definition>
        </repeat>
      </repeat>
    </transform>
  </coordinates>

  <annotations text="Trajectories for a spiral repellor shown in the standard coordinate system">
    <annotation ref="std-axes"
                text="The standard axes"/>
    <annotation ref="grid"
                text="A coordinate grid defined by the eigenvectors"/>
    <annotation ref="curves"/>
  </annotations>
  
</diagram>
