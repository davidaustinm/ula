<diagram xmlns="https://prefigure.org"
         dimensions="(250, 250)" margins="5">
  <coordinates bbox="(-4,-4,4,4)">
    <grid-axes decorations="no"/>
    <vector at="v" v="(-2,2)" tail="(1,2)" stroke="blue"/>
    <point at="p" p="(1,2)" fill="gray" size="2"/>
  </coordinates>

  <annotations text="Finally, we translate the rotated vector back to the point p">
    <annotation ref="p" text="The point p"/>
    <annotation ref="v" text="The rotated vector has been translated back to p"/>
  </annotations>
</diagram>    
